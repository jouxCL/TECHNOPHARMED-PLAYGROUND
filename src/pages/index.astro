---
import Navbar from '../components/Navbar.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Technopharmed – Soluciones Farmacéuticas</title>
    <style>
      /* ─── RESET MINIMAL ─── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, Helvetica, sans-serif; color: #111; background: #fff; }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }

      /* ─── PLACEHOLDER IMAGE (patrón misssing-texture magenta/negro) ─── */
      .img-placeholder {
        width: 100%;
        aspect-ratio: 16 / 9;
        background-image:
          repeating-conic-gradient(#000 0% 25%, #ff00ff 0% 50%);
        background-size: 32px 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        text-shadow: 0 1px 3px #000;
      }
      .img-placeholder--tall { aspect-ratio: 4 / 3; }
      .img-placeholder--square { aspect-ratio: 1 / 1; }

      /* ─── ICON GENÉRICO ─── */
      .icon-generic {
        width: 48px;
        height: 48px;
        flex-shrink: 0;
      }

      /* ─── BOTÓN SIMPLE ─── */
      .btn {
        display: inline-block;
        padding: 0.6rem 1.4rem;
        border: 2px solid #333;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: bold;
        background: transparent;
      }

      /* ─── HERO ─── */
      .hero {
        position: relative;
        overflow: hidden;
      }
      .hero .img-placeholder { aspect-ratio: 21 / 9; }
      .hero__overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: #fff;
        padding: 2rem;
        gap: 1rem;
      }
      .hero__title   { font-size: clamp(1.4rem, 4vw, 2.6rem); font-weight: 800; }
      .hero__subtitle { font-size: clamp(1rem, 2vw, 1.3rem); max-width: 700px; }

      /* ─── SECCIONES GENÉRICAS ─── */
      .section { padding: 3rem 2rem; max-width: 1200px; margin: 0 auto; }
      .section-title { font-size: 1.6rem; font-weight: 700; margin-bottom: 2rem; }

      /* ─── GRID DE SOLUCIONES ─── */
      .solutions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
      }
      .solution-card {
        border: 1px solid #ccc;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      .solution-card__logos {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        flex-wrap: wrap;
      }
      .logo-badge {
        border: 1px solid #888;
        padding: 0.2rem 0.6rem;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        background: #f5f5f5;
      }
      .solution-card__title { font-size: 1.1rem; font-weight: 700; }
      .solution-card p { font-size: 0.9rem; line-height: 1.5; color: #333; }
      .restriction-note {
        font-size: 0.75rem;
        color: #c00;
        font-style: italic;
      }

      /* ─── COMPROMISO / SERVICIO ─── */
      .commitment-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
        margin: 1.5rem 0;
      }
      .commitment-item {
        border: 1px solid #ddd;
        padding: 1.25rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }
      .commitment-item p { font-size: 0.9rem; line-height: 1.5; }

      /* ─── FOOTER ─── */
      footer {
        background: #111;
        color: #eee;
        padding: 3rem 2rem;
      }
      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }
      .footer-logo { font-size: 1.4rem; font-weight: 800; letter-spacing: 0.1em; color: #fff; }
      .footer-tagline { font-size: 0.95rem; color: #bbb; margin-top: 0.25rem; }

      .footer-contact { display: flex; flex-direction: column; gap: 0.5rem; }
      .footer-contact-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.9rem;
      }
      .footer-directory { font-size: 0.85rem; line-height: 1.8; color: #ccc; }
      .footer-directory strong { color: #fff; }
      hr.footer-hr { border: none; border-top: 1px solid #333; }
    </style>
  </head>

  <body>

    <!-- ════════════ NAVBAR ════════════ -->
    <Navbar />

    <!-- ════════════ HERO ════════════ -->
    <section class="hero">
      <div class="img-placeholder">
        <span>IMAGEN PLACEHOLDER</span>
      </div>
      <div class="hero__overlay">
        <h1 class="hero__title">Optimizamos sus procesos de producción con innovación y alta calidad.</h1>
        <p class="hero__subtitle">Más de 20 años de experiencia garantizando estándares de calidad con equipos de última generación.</p>
        <a href="#contacto" class="btn" style="color:#fff; border-color:#fff;">Solicitar Asesoría Personalizada</a>
      </div>
    </section>

    <!-- ════════════ NUESTRAS SOLUCIONES ════════════ -->
    <section class="section">
      <h2 class="section-title">Soluciones adaptadas para maximizar su productividad.</h2>

      <div class="solutions-grid">

        <!-- BLOQUE 1: PUNZONERÍA -->
        <div class="solution-card">
          <div class="solution-card__logos">
            <span class="logo-badge">I Holland</span>
            <span class="logo-badge">Technopharmed</span>
          </div>
          <div class="img-placeholder img-placeholder--tall"><span>IMAGEN PLACEHOLDER</span></div>
          <h3 class="solution-card__title">Punzones, Matrices y Mantenimiento.</h3>
          <p>Proveedor líder mundial con más de 75 años de experiencia en investigación y desarrollo.</p>
          <p>Ofrecemos el proceso de "Los 7 Pasos del Mantenimiento" para extender la vida útil de sus herramientas.</p>
          <p>Sistema de Gestión IH-TMS compatible con CFR 21 Parte 11.</p>
          <a href="#" class="btn">Conocer línea I Holland</a>
        </div>

        <!-- BLOQUE 2: LLENADORAS DE LÍQUIDOS -->
        <div class="solution-card">
          <div class="solution-card__logos">
            <span class="logo-badge">Filamatic</span>
          </div>
          <div class="img-placeholder img-placeholder--tall"><span>IMAGEN PLACEHOLDER</span></div>
          <h3 class="solution-card__title">Llenadoras de Líquidos.</h3>
          <p>Equipos versátiles que van desde sistemas semiautomáticos (Benchtop Series) hasta sistemas integrados y monobloques (Fusion 2, FlexFIL).</p>
          <p>Soluciones rentables y de calidad para dosificación controlada de productos líquidos, viscosos y fundidos.</p>
          <a href="#" class="btn">Explorar Llenadoras Filamatic</a>
        </div>

        <!-- BLOQUE 3: TABLETEADORAS -->
        <div class="solution-card">
          <p class="restriction-note">⚠ Sin logos de proveedores específicos en este bloque.</p>
          <div class="img-placeholder img-placeholder--tall"><span>IMAGEN PLACEHOLDER</span></div>
          <h3 class="solution-card__title">Máquinas Tableteadoras.</h3>
          <p>Equipos que combinan versatilidad y tecnología avanzada para garantizar precisión y eficiencia.</p>
          <p>Capacidades que abarcan desde escalas piloto y de desarrollo hasta máquinas rotativas de alta velocidad.</p>
          <p>Sistemas con automatización, cabezales intercambiables y cumplimiento normativo CFR 21 Parte 11 para procesos seguros.</p>
          <a href="#" class="btn">Ver Equipos de Compresión</a>
        </div>

      </div>
    </section>

    <!-- ════════════ COMPROMISO Y SERVICIO TÉCNICO ════════════ -->
    <section class="section" style="background:#f8f8f8; max-width: 100%; padding-left:0; padding-right:0;">
      <div style="max-width:1200px; margin:0 auto; padding: 3rem 2rem;">

        <h2 class="section-title">#1 en Satisfacción del Cliente.</h2>

        <div class="commitment-grid">

          <div class="commitment-item">
            <!-- Ícono genérico: reloj / disponibilidad -->
            <svg class="icon-generic" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="20" stroke="#111" stroke-width="3"/>
              <path d="M24 12v12l8 8" stroke="#111" stroke-width="3" stroke-linecap="round"/>
            </svg>
            <p>Soporte técnico disponible las 24 horas.</p>
          </div>

          <div class="commitment-item">
            <!-- Ícono genérico: persona / asesoría -->
            <svg class="icon-generic" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="16" r="8" stroke="#111" stroke-width="3"/>
              <path d="M8 40c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="#111" stroke-width="3" stroke-linecap="round"/>
            </svg>
            <p>Venta técnica y asesoría personalizada adaptada a sus necesidades.</p>
          </div>

          <div class="commitment-item">
            <!-- Ícono genérico: pizarrón / capacitación -->
            <svg class="icon-generic" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="8" width="36" height="26" rx="2" stroke="#111" stroke-width="3"/>
              <path d="M18 40h12M24 34v6" stroke="#111" stroke-width="3" stroke-linecap="round"/>
              <path d="M14 20h20M14 27h12" stroke="#111" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            <p>Programas completos de capacitación en instalaciones del cliente.</p>
          </div>

        </div>

        <p style="font-size:1.05rem; font-weight:600; margin-top:1rem;">
          Nuestra filosofía de servicio y experiencia son nuestra mejor carta de garantía.
        </p>

      </div>
    </section>

    <!-- ════════════ FOOTER ════════════ -->
    <footer id="contacto">
      <div class="footer-inner">

        <div>
          <div class="footer-logo">TECHNOPHARMED</div>
          <p class="footer-tagline">Compromiso, Respaldo e Innovación.</p>
        </div>

        <hr class="footer-hr" />

        <!-- INFORMACIÓN DE CONTACTO DIRECTO -->
        <div class="footer-contact">

          <div class="footer-contact-item">
            <!-- Ícono ubicación -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z" stroke="#eee" stroke-width="2"/>
              <circle cx="12" cy="9" r="2.5" stroke="#eee" stroke-width="2"/>
            </svg>
            <span>Carrera 3F Nº 32A - 13, Manizales - Colombia.</span>
          </div>

          <div class="footer-contact-item">
            <!-- Ícono teléfono -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="#eee" stroke-width="2"/>
            </svg>
            <span>(+57) 313 831 1426</span>
          </div>

          <div class="footer-contact-item">
            <!-- Ícono web/globe -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10" stroke="#eee" stroke-width="2"/>
              <path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke="#eee" stroke-width="2"/>
            </svg>
            <a href="https://www.technopharmed.com" target="_blank" style="color:#eee;">www.technopharmed.com</a>
          </div>

        </div>

        <hr class="footer-hr" />

        <!-- DIRECTORIO DE SOPORTE -->
        <div class="footer-directory">
          <p><strong>Directorio de Soporte</strong></p>
          <p>Gerencia: Ing. Juan Quintero &nbsp;|&nbsp; <a href="mailto:gerencia@technopharmed.com" style="color:#bbb;">gerencia@technopharmed.com</a> &nbsp;|&nbsp; Tel: 313 831 1426</p>
          <p>Administrativo: Claudia Santa &nbsp;|&nbsp; <a href="mailto:administrativo@technopharmed.com" style="color:#bbb;">administrativo@technopharmed.com</a> &nbsp;|&nbsp; Tel: 313 627 36 94</p>
          <p>Asistencia: Laura Uribe &nbsp;|&nbsp; <a href="mailto:asistente@technopharmed.com" style="color:#bbb;">asistente@technopharmed.com</a> &nbsp;|&nbsp; Tel: 318 837 6804</p>
        </div>

      </div>
    </footer>

  </body>
</html>
