---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Technopharmed – Soluciones Farmacéuticas">
  
  

  

<!-- ═══ HERO ═══ -->
    <section class="hero" id="inicio">
      <div class="hero-deco">
        <div class="hero-deco__ring-1"></div>
        <div class="hero-deco__ring-2"></div>
        <div class="hero-deco__ring-3"></div>
        <div class="hero-deco__blob"></div>
        <div class="hero-deco__line hero-deco__line-1"></div>
        <div class="hero-deco__line hero-deco__line-2"></div>
        <div class="hero-deco__line hero-deco__line-3"></div>
        <div class="hero-deco__dots"></div>
        <div class="hero-deco__dots-tr"></div>
        <div class="hero-deco__accent"></div>

        <!-- SVG arc lines across hero -->
        <svg class="hero-deco__arc-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120" preserveAspectRatio="none" height="120">
          <path d="M0,60 Q360,120 720,60 Q1080,0 1440,60" fill="none" stroke="rgba(158,202,255,0.08)" stroke-width="1"/>
          <path d="M0,80 Q360,20 720,80 Q1080,140 1440,80" fill="none" stroke="rgba(158,202,255,0.05)" stroke-width="1"/>
        </svg>
      </div>

      <div class="hero__inner">
        <div class="hero__content">
          <span class="hero__eyebrow">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21.02 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Más de 20 años en el sector
          </span>
          <h1 class="hero__title">
            Optimizamos sus<br/>
            <em>procesos farmacéuticos</em><br/>
            con innovación.
          </h1>
          <p class="hero__subtitle">
            Garantizamos estándares internacionales de calidad con equipos de última generación y soporte técnico sin igual.
          </p>
          <div class="hero__actions">
            <md-filled-button href="#contacto">Solicitar Asesoría</md-filled-button>
            <md-outlined-button href="#soluciones">Ver Soluciones</md-outlined-button>
          </div>
        </div>

        <div class="hero__visual">
          <div class="hero__stat-row">
            <div class="hero__stat">
              <div class="hero__stat-number" data-count="20" data-suffix="+">+20</div>
              <div class="hero__stat-label">Años de<br/>experiencia</div>
            </div>
            <div class="hero__stat">
              <div class="hero__stat-number" data-count="3">3</div>
              <div class="hero__stat-label">Líneas de<br/>solución</div>
            </div>
            <div class="hero__stat">
              <div class="hero__stat-number" style="font-size:1.7rem;">24/7</div>
              <div class="hero__stat-label">Soporte<br/>disponible</div>
            </div>
          </div>
          <div class="hero__badge">
            <div class="hero__badge-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="hero__badge-text">
              <p>Cumplimiento CFR 21 Parte 11</p>
              <p>Equipos certificados para industria farmacéutica</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Wave -->
    <div class="wave" style="background:var(--md-surface-container); margin-top:-2px;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 56" preserveAspectRatio="none" height="56">
        <path fill="#F8F9FC" d="M0,28 C480,56 960,0 1440,28 L1440,0 L0,0 Z"/>
      </svg>
    </div>

    <!-- ═══ SOLUTIONS ═══ -->
    <section class="section solutions-section" id="soluciones">
      <!-- Deco elements -->
      <div class="sol-deco__sq-1"></div>
      <div class="sol-deco__sq-2"></div>
      <div class="sol-deco__tri"></div>
      <div class="section-inner">
        <p class="section-eyebrow reveal">Nuestras Soluciones</p>
        <h2 class="section-title reveal stagger-1">Equipos adaptados para maximizar su productividad.</h2>
        <p class="section-subtitle reveal stagger-2">Representamos las mejores marcas del mundo para ofrecer tecnología probada, respaldada por nuestro equipo experto.</p>

        <div class="solutions-grid">
          <md-elevated-card class="sol-card reveal stagger-1">
            <div class="sol-card-inner">
              <div class="chip-row">
                <span class="m3-chip">I Holland</span>
                <span class="m3-chip">Technopharmed</span>
              </div>
              <div class="img-placeholder"><span>Imagen Placeholder</span></div>
              <h3 class="card-title">Punzones, Matrices y Mantenimiento.</h3>
              <p class="card-body">Proveedor líder mundial con más de 75 años en I+D. Los 7 Pasos del Mantenimiento para extender la vida útil. Sistema IH-TMS compatible con CFR 21 Parte 11.</p>
              <div class="card-action"><md-text-button href="#">Conocer I Holland →</md-text-button></div>
            </div>
          </md-elevated-card>

          <md-elevated-card class="sol-card reveal stagger-2">
            <div class="sol-card-inner">
              <div class="chip-row"><span class="m3-chip">Filamatic</span></div>
              <div class="img-placeholder"><span>Imagen Placeholder</span></div>
              <h3 class="card-title">Llenadoras de Líquidos.</h3>
              <p class="card-body">Desde sistemas semiautomáticos Benchtop hasta monobloques integrados Fusion 2 y FlexFIL. Dosificación controlada de productos líquidos, viscosos y fundidos.</p>
              <div class="card-action"><md-text-button href="#">Explorar Filamatic →</md-text-button></div>
            </div>
          </md-elevated-card>

          <md-elevated-card class="sol-card reveal stagger-3">
            <div class="sol-card-inner">
              <div class="chip-row"><span class="m3-chip m3-chip--tertiary">Nueva Línea</span></div>
              <div class="img-placeholder"><span>Imagen Placeholder</span></div>
              <h3 class="card-title">Máquinas Tableteadoras.</h3>
              <p class="card-body">Desde escala piloto hasta rotativas de alta velocidad. Automatización avanzada, cabezales intercambiables y cumplimiento normativo CFR 21 Parte 11.</p>
              <div class="card-action"><md-text-button href="#">Ver Tableteadoras →</md-text-button></div>
            </div>
          </md-elevated-card>
        </div>
      </div>
    </section>

    <!-- Wave -->
    <div class="wave" style="background:var(--md-bg); margin-top:-2px;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 56" preserveAspectRatio="none" height="56">
        <path fill="var(--md-surface-container)" d="M0,28 C480,56 960,0 1440,28 L1440,0 L0,0 Z"/>
      </svg>
    </div>

    <!-- ═══ NUMBERS ═══ -->
    <section class="numbers-section">
      <div class="num-deco__orb-1"></div>
      <div class="num-deco__orb-2"></div>
      <div class="numbers-inner">
        <div class="num-item reveal">
          <div class="num-value"><span class="counter" data-target="20" data-prefix="+">+20</span></div>
          <div class="num-label">Años de experiencia en el sector farmacéutico</div>
        </div>
        <div class="num-item reveal stagger-1">
          <div class="num-value"><span class="counter" data-target="100" data-suffix="%">100%</span></div>
          <div class="num-label">Compromiso con la calidad y el cliente</div>
        </div>
        <div class="num-item reveal stagger-2">
          <div class="num-value"><span class="counter" data-target="3">3</span></div>
          <div class="num-label">Líneas de solución especializadas</div>
        </div>
        <div class="num-item reveal stagger-3">
          <div class="num-value">24<span style="font-size:1.6rem;color:var(--md-inverse-primary);">/7</span></div>
          <div class="num-label">Soporte técnico disponible</div>
        </div>
      </div>
    </section>

    <!-- Wave -->
    <div class="wave" style="background:var(--md-bg); margin-top:-2px;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 56" preserveAspectRatio="none" height="56">
        <path fill="var(--md-bg)" d="M0,28 C480,56 960,0 1440,28 L1440,0 L0,0 Z"/>
      </svg>
    </div>

    <!-- ═══ COMMITMENT ═══ -->
    <section class="section commitment-section">
      <!-- Floating deco -->
      <div class="com-deco__ring"></div>
      <div class="com-deco__ring-2"></div>
      <div class="com-deco__diamond"></div>
      <div class="section-inner">
        <p class="section-eyebrow reveal">Nuestra Filosofía</p>
        <h2 class="section-title reveal stagger-1">#1 en Satisfacción del Cliente.</h2>
        <p class="section-subtitle reveal stagger-2">Nuestra experiencia y compromiso son la mejor garantía. Acompañamos cada etapa del proceso productivo.</p>

        <div class="commitment-grid">
          <div class="commitment-card reveal stagger-1">
            <div class="c-icon">
              <svg width="28" height="28" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="3"/><path d="M24 12v12l8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
            </div>
            <div class="c-title">Soporte 24/7</div>
            <p class="c-body">Nuestro equipo técnico está disponible las 24 horas del día para que su producción nunca se detenga.</p>
          </div>

          <div class="commitment-card reveal stagger-2">
            <div class="c-icon">
              <svg width="28" height="28" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="16" r="8" stroke="currentColor" stroke-width="3"/><path d="M8 40c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
            </div>
            <div class="c-title">Asesoría Personalizada</div>
            <p class="c-body">Consultoría técnica especializada adaptada a las necesidades únicas de cada cliente y proceso.</p>
          </div>

          <div class="commitment-card reveal stagger-3">
            <div class="c-icon">
              <svg width="28" height="28" viewBox="0 0 48 48" fill="none"><rect x="6" y="8" width="36" height="26" rx="2" stroke="currentColor" stroke-width="3"/><path d="M18 40h12M24 34v6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><path d="M14 20h20M14 27h12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            </div>
            <div class="c-title">Capacitación In-Situ</div>
            <p class="c-body">Programas completos de formación directamente en sus instalaciones con instructores especializados.</p>
          </div>

          <div class="commitment-card reveal stagger-4">
            <div class="c-icon">
              <svg width="28" height="28" viewBox="0 0 48 48" fill="none"><path d="M24 6l4 8 9 1.3-6.5 6.4 1.5 9L24 26l-8 4.7 1.5-9L11 15.3l9-1.3L24 6z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/><path d="M12 36l2 6M36 36l-2 6M18 42h12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            </div>
            <div class="c-title">Calidad Certificada</div>
            <p class="c-body">Todos nuestros equipos cumplen con las más exigentes normativas farmacéuticas internacionales.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section class="section cta-section" id="contacto">
      <div class="cta-deco__ring"></div>
      <div class="cta-deco__ring-2"></div>
      <div class="cta-inner">
        <div class="cta-glow">
        <div class="cta-badge reveal">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          Contáctenos hoy
        </div>
        <h2 class="cta-title reveal stagger-1">¿Listo para optimizar su producción?</h2>
        <p class="cta-subtitle reveal stagger-2">Nuestro equipo de expertos está listo para asesorarle y encontrar la solución perfecta para sus necesidades farmacéuticas.</p>
        <div class="cta-actions reveal stagger-3">
          <md-filled-button href="mailto:gerencia@technopharmed.com">Contactar Ahora</md-filled-button>
          <md-outlined-button href="https://www.technopharmed.com" target="_blank">Visitar Sitio Web</md-outlined-button>
        </div>
        </div> <!-- /cta-glow -->
      </div>
    </section>

    

    <script>
      /* ══ HERO PARTICLE CANVAS – Enhanced ══ */
      const heroEl = document.querySelector('.hero') as HTMLElement;
      if (heroEl) {
        const canvas = document.createElement('canvas');
        Object.assign(canvas.style, {
          position:'absolute', inset:'0', width:'100%', height:'100%',
          pointerEvents:'none', zIndex:'1'
        });
        heroEl.appendChild(canvas);
        const ctx = canvas.getContext('2d')!;
        const resize = () => { canvas.width = heroEl.offsetWidth; canvas.height = heroEl.offsetHeight; };
        resize();
        window.addEventListener('resize', resize);

        /* Mouse tracking for repulsion */
        const mouse = { x: -9999, y: -9999 };
        heroEl.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = heroEl.getBoundingClientRect();
          mouse.x = e.clientX - rect.left;
          mouse.y = e.clientY - rect.top;
        });
        heroEl.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

        interface Particle {
          x: number; y: number;
          baseR: number; r: number;
          vy: number; vx: number;
          alpha: number;
          phase: number; /* for sine pulse */
          speed: number;
          hue: number;   /* slight color tint variation */
        }
        const COUNT = 80;
        const particles: Particle[] = Array.from({ length: COUNT }, () => ({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          baseR: Math.random() * 3 + 0.6,
          r: 1,
          vy: -(Math.random() * 0.55 + 0.08),
          vx: (Math.random() - 0.5) * 0.3,
          alpha: Math.random() * 0.55 + 0.15,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.02 + 0.015,
          hue: Math.random() * 30 - 15, /* -15 to +15 degrees around blue */
        }));

        let tick = 0;
        const CONNECT_DIST = 100;
        const REPEL_DIST   = 90;
        const REPEL_FORCE  = 1.8;

        const animate = () => {
          tick++;
          ctx.clearRect(0, 0, canvas.width, canvas.height);

          /* ─ Draw connecting lines ─ */
          for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < CONNECT_DIST) {
                const lineAlpha = (1 - dist / CONNECT_DIST) * 0.18;
                ctx.beginPath();
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.strokeStyle = `rgba(158,202,255,${lineAlpha})`;
                ctx.lineWidth = 0.7;
                ctx.stroke();
              }
            }
          }

          /* ─ Draw & move particles ─ */
          particles.forEach(p => {
            /* Pulsing radius via sine wave */
            p.phase += p.speed;
            p.r = p.baseR + Math.sin(p.phase) * (p.baseR * 0.5);

            /* Mouse repulsion */
            const dx = p.x - mouse.x;
            const dy = p.y - mouse.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < REPEL_DIST && dist > 0) {
              const force = (REPEL_DIST - dist) / REPEL_DIST * REPEL_FORCE;
              p.x += (dx / dist) * force;
              p.y += (dy / dist) * force;
            }

            /* Movement */
            p.y += p.vy;
            p.x += p.vx;
            if (p.y < -10) { p.y = canvas.height + 10; p.x = Math.random() * canvas.width; }
            if (p.x < -10) p.x = canvas.width + 10;
            if (p.x > canvas.width + 10) p.x = -10;

            /* Glow via shadowBlur */
            ctx.save();
            ctx.shadowColor = `hsla(${210 + p.hue}, 100%, 80%, 0.7)`;
            ctx.shadowBlur = p.r * 5;

            /* Draw circle */
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = `hsla(${210 + p.hue}, 100%, 85%, ${p.alpha})`;
            ctx.fill();
            ctx.restore();
          });

          requestAnimationFrame(animate);
        };
        animate();
      }

      /* ══ CARD TILT (subtle 3D perspective on mouse move) ══ */
      document.querySelectorAll<HTMLElement>('.commitment-card').forEach(card => {
        card.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top)  / rect.height - 0.5;
          card.style.transform = `translateY(-5px) rotateY(${x*6}deg) rotateX(${-y*6}deg)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = '';
        });
      });
    </script>
</Layout>

<style is:global>

      /* ════════════════════════════════════
         HERO
         ════════════════════════════════════ */
      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        background:
          radial-gradient(ellipse 80% 60% at 70% 50%, color-mix(in srgb, var(--md-primary) 60%, #001a33) 0%, transparent 70%),
          linear-gradient(160deg, #001D36 0%, #003570 45%, #00529A 100%);
      }

      /* ── Geometric deco shapes ── */
      .hero-deco {
        position: absolute; inset: 0; pointer-events: none; overflow: hidden;
      }
      /* Large arc ring top-right */
      .hero-deco__ring-1 {
        position: absolute;
        width: 700px; height: 700px;
        border-radius: 50%;
        border: 1.5px solid rgba(158,202,255,0.12);
        top: -200px; right: -180px;
        animation: slowSpin 60s linear infinite;
      }
      .hero-deco__ring-2 {
        position: absolute;
        width: 460px; height: 460px;
        border-radius: 50%;
        border: 1px solid rgba(158,202,255,0.08);
        top: -80px; right: -50px;
        animation: slowSpin 40s linear infinite reverse;
      }
      /* Diagonal lines */
      .hero-deco__line {
        position: absolute;
        width: 1px;
        height: 220px;
        background: linear-gradient(to bottom, transparent, rgba(158,202,255,0.2), transparent);
        transform-origin: center;
      }
      .hero-deco__line-1 { right: 22%; top: 10%; transform: rotate(25deg); animation: linePulse 4s ease-in-out infinite; }
      .hero-deco__line-2 { right: 30%; top: 30%; transform: rotate(-15deg); animation: linePulse 4s ease-in-out infinite 1.3s; }
      .hero-deco__line-3 { right: 15%; top: 50%; transform: rotate(45deg); animation: linePulse 4s ease-in-out infinite 0.7s; }
      /* Dot grid */
      .hero-deco__dots {
        position: absolute;
        bottom: 60px; left: 48px;
        width: 120px; height: 120px;
        background-image: radial-gradient(circle, rgba(158,202,255,0.25) 1.5px, transparent 1.5px);
        background-size: 20px 20px;
        opacity: 0.7;
      }
      /* Small accent circle */
      .hero-deco__accent {
        position: absolute;
        width: 180px; height: 180px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(158,202,255,0.08) 0%, transparent 70%);
        bottom: 80px; right: 10%;
        animation: breathe 5s ease-in-out infinite;
      }

      @keyframes slowSpin   { to { transform: rotate(360deg); } }
      @keyframes slowSpinRev  { to { transform: rotate(-360deg); } }
      @keyframes linePulse  { 0%,100%{opacity:.3} 50%{opacity:1} }
      @keyframes breathe    { 0%,100%{transform:scale(1)} 50%{transform:scale(1.18)} }
      @keyframes floatY     { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-18px)} }
      @keyframes floatX     { 0%,100%{transform:translateX(0)} 50%{transform:translateX(14px)} }
      @keyframes morphBlob  {
        0%   { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
        33%  { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
        66%  { border-radius: 50% 60% 40% 30% / 40% 70% 60% 50%; }
        100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
      }
      @keyframes shimmerSlide { from{transform:translateX(-100%)} to{transform:translateX(200%)} }
      @keyframes glowPulse  { 0%,100%{box-shadow:0 0 20px rgba(0,82,154,.2)} 50%{box-shadow:0 0 50px rgba(0,82,154,.5)} }
      @keyframes rotateDash { to { stroke-dashoffset: -200; } }
      @keyframes popIn      { from{opacity:0;transform:scale(.5)} to{opacity:1;transform:scale(1)} }
      @keyframes gradShift  {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }

      /* ── Extra hero deco: third ring + blob + small dots top-right ── */
      .hero-deco__ring-3 {
        position:absolute; width:280px; height:280px; border-radius:50%;
        border: 1px dashed rgba(158,202,255,0.07);
        top: 40%; right: 5%;
        animation: slowSpin 30s linear infinite;
      }
      .hero-deco__blob {
        position:absolute; width:340px; height:340px;
        background: radial-gradient(circle, rgba(0,82,154,.22) 0%, transparent 70%);
        right: 2%; top: 15%;
        animation: morphBlob 12s ease-in-out infinite, breathe 7s ease-in-out infinite;
      }
      .hero-deco__orb-1 {
        position:absolute; width:10px; height:10px; border-radius:50%;
        background: rgba(158,202,255,0.5);
        left: 42%; top: 20%;
        animation: floatY 3.5s ease-in-out infinite, linePulse 3.5s ease-in-out infinite;
      }
      .hero-deco__orb-2 {
        position:absolute; width:6px; height:6px; border-radius:50%;
        background: rgba(255,255,255,0.4);
        left: 55%; top: 70%;
        animation: floatY 4.5s ease-in-out infinite 1s, linePulse 4s ease-in-out infinite .5s;
      }
      .hero-deco__orb-3 {
        position:absolute; width:14px; height:14px; border-radius:50%;
        background: rgba(158,202,255,0.25);
