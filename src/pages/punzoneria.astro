---
import Navbar from '../components/Navbar.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Punzonería – Technopharmed</title>
    <style>
      /* ─── RESET MINIMAL ─── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, Helvetica, sans-serif; color: #111; background: #fff; }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }

      /* ─── PLACEHOLDER (patrón misssing-texture magenta/negro) ─── */
      .img-placeholder {
        width: 100%;
        background-image: repeating-conic-gradient(#000 0% 25%, #ff00ff 0% 50%);
        background-size: 32px 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        text-shadow: 0 1px 3px #000;
      }
      .img-placeholder--hero    { aspect-ratio: 21 / 9; }
      .img-placeholder--wide    { aspect-ratio: 16 / 6; }
      .img-placeholder--medium  { aspect-ratio: 16 / 7; }

      /* ─── ÍCONO GENÉRICO ─── */
      .icon-generic {
        width: 40px; height: 40px; flex-shrink: 0;
      }

      /* ─── BOTÓN ─── */
      .btn {
        display: inline-block;
        padding: 0.6rem 1.4rem;
        border: 2px solid #333;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: bold;
        background: transparent;
      }

      /* ─── SECCIÓN ─── */
      .section { padding: 3rem 2rem; }
      .section--shaded { background: #f8f8f8; }
      .section__inner { max-width: 1100px; margin: 0 auto; }
      .section-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 1.25rem; }
      .section-text  { font-size: 0.95rem; line-height: 1.65; color: #333; margin-bottom: 0.75rem; }

      /* ─── HERO ─── */
      .hero { position: relative; overflow: hidden; }
      .hero__overlay {
        position: absolute; inset: 0;
        background: rgba(0,0,0,0.52);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; color: #fff; padding: 2rem; gap: 1rem;
      }
      .hero__logos {
        display: flex; gap: 0.75rem; align-items: center;
        justify-content: center; flex-wrap: wrap;
      }
      .hero__logo-badge {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.5);
        padding: 0.25rem 0.8rem;
        font-size: 0.7rem; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
      }
      .hero__title    { font-size: clamp(1.4rem, 3.5vw, 2.5rem); font-weight: 800; max-width: 800px; }
      .hero__subtitle { font-size: clamp(0.95rem, 1.8vw, 1.2rem); max-width: 700px; line-height: 1.6; }

      /* ─── SECCIÓN 1: SUB-BLOQUES ─── */
      .sub-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-top: 1.5rem;
      }
      .sub-card {
        border: 1px solid #ccc;
        padding: 1.25rem;
        display: flex; flex-direction: column; gap: 0.75rem;
      }
      .sub-card__title { font-size: 1rem; font-weight: 700; }
      .sub-card p { font-size: 0.9rem; line-height: 1.6; color: #333; }

      /* ─── SECCIÓN 2: COLUMNAS MATERIALES ─── */
      .col-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
        margin-top: 1.5rem;
      }
      .col-card {
        border-left: 4px solid #333;
        padding: 1rem 1.25rem;
        display: flex; flex-direction: column; gap: 0.6rem;
      }
      .col-card__label {
        font-size: 0.8rem; font-weight: 800;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: #555;
      }
      .col-card__name { font-size: 1.1rem; font-weight: 700; }
      .col-card p { font-size: 0.9rem; line-height: 1.6; color: #333; }

      /* ─── SECCIÓN 3: PHARMACARE CON IMAGEN ─── */
      .pharmacare-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: start;
        margin-top: 1.25rem;
      }
      @media (max-width: 700px) { .pharmacare-layout { grid-template-columns: 1fr; } }
      .pharmacare-list { list-style: none; padding: 0; margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0.5rem; }
      .pharmacare-list li {
        display: flex; align-items: flex-start; gap: 0.6rem;
        font-size: 0.9rem; line-height: 1.55; color: #333;
      }

      /* ─── SECCIÓN 4: DESTACADO IH-TMS ─── */
      .highlight-box {
        border: 2px solid #111;
        padding: 1.25rem 1.5rem;
        margin-top: 1.25rem;
        display: flex; gap: 1rem; align-items: flex-start;
      }
      .highlight-box p { font-size: 0.95rem; line-height: 1.65; color: #222; }

      /* ─── SECCIÓN 5: CAPACITACIÓN ─── */
      .training-topics {
        display: flex; flex-wrap: wrap; gap: 0.75rem;
        margin: 1rem 0 1.5rem;
      }
      .training-tag {
        border: 1px solid #888;
        padding: 0.3rem 0.85rem;
        font-size: 0.82rem; font-weight: 600; color: #333;
        background: #f5f5f5;
      }
    </style>
  </head>

  <body>

    <!-- ════════════ NAVBAR ════════════ -->
    <Navbar />

    <!-- ════════════ HERO ════════════ -->
    <section class="hero">
      <div class="img-placeholder img-placeholder--hero"><span>IMAGEN PLACEHOLDER</span></div>
      <div class="hero__overlay">
        <div class="hero__logos">
          <span class="hero__logo-badge">Technopharmed</span>
          <span class="hero__logo-badge">I Holland · Tabletting Science</span>
        </div>
        <h1 class="hero__title">Punzones, Matrices y Segmentos de Alta Precisión.</h1>
        <p class="hero__subtitle">
          I Holland se ha consolidado como el principal proveedor mundial de punzones, matrices y segmentos para fabricantes de tabletas en todo el mundo. Contamos con casi 80 años de experiencia en la industria de las tabletas.
        </p>
        <a href="#contacto" class="btn" style="color:#fff; border-color:#fff;">Solicitar Asesoría Técnica</a>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 1: HERRAMIENTAS A MEDIDA ════════════ -->
    <section class="section">
      <div class="section__inner">
        <h2 class="section-title">Fabricación a la Medida de sus Especificaciones.</h2>
        <p class="section-text">
          Cada herramienta que fabricamos está hecha a medida y según sus especificaciones exactas.
          <strong>¡Nuestras herramientas para tabletas con forma son completamente intercambiables como estándar sin costo adicional!</strong>
        </p>

        <div class="sub-grid">

          <!-- SUB-BLOQUE A: PUNTAS MÚLTIPLES -->
          <div class="sub-card">
            <div class="img-placeholder img-placeholder--medium"><span>IMAGEN PLACEHOLDER</span></div>
            <h3 class="sub-card__title">Puntas Múltiples</h3>
            <p>
              Si necesita aumentar la producción de tabletas por hora sin realizar gastos de capital ni aumentar el espacio disponible, la solución más eficaz es utilizar varias puntas en una perforadora.
            </p>
          </div>

          <!-- SUB-BLOQUE B: SEGMENTOS DE TROQUEL -->
          <div class="sub-card">
            <div class="img-placeholder img-placeholder--medium"><span>IMAGEN PLACEHOLDER</span></div>
            <h3 class="sub-card__title">Segmentos de Troquel</h3>
            <p>
              Los segmentos de matriz sustituyen la mesa de matriz y las matrices de torreta estándar originales. Se producen con los más altos estándares de calidad y se inspeccionan al 100%.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 2: MATERIALES Y RECUBRIMIENTOS ════════════ -->
    <section class="section section--shaded">
      <div class="section__inner">
        <h2 class="section-title">Innovación en Aceros y Superficies.</h2>

        <div class="col-grid">

          <!-- COLUMNA 1: PHARMAGRADE -->
          <div class="col-card">
            <span class="col-card__label">Línea de Aceros</span>
            <span class="col-card__name">PharmaGrade®</span>
            <p>
              Una buena selección de acero mejora la resistencia de la herramienta y aumenta la tenacidad.
              Compare los aceros PharmaGrade® para obtener herramientas más resistentes y duraderas.
            </p>
          </div>

          <!-- COLUMNA 2: PHARMACOTE -->
          <div class="col-card">
            <span class="col-card__label">Recubrimientos</span>
            <span class="col-card__name">PharmaCote®</span>
            <p>
              Los recubrimientos para herramientas especialmente formulados brindan protección antiadherente, contra el desgaste y la corrosión.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 3: MANTENIMIENTO - PHARMACARE ════════════ -->
    <section class="section">
      <div class="section__inner">
        <h2 class="section-title">El Proceso de 7 Pasos PharmaCare®.</h2>

        <div class="pharmacare-layout">

          <!-- IMAGEN -->
          <div class="img-placeholder img-placeholder--wide"><span>IMAGEN PLACEHOLDER</span></div>

          <!-- CONTENIDO -->
          <div>
            <p class="section-text">
              Un proceso de 7 pasos para reducir el tiempo de inactividad y prolongar la vida útil de las herramientas.
            </p>
            <p class="section-text" style="font-weight:600; margin-bottom:0.5rem;">Equipos ofrecidos:</p>
            <ul class="pharmacare-list">
              <li>
                <svg class="icon-generic" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="20" cy="20" r="18" stroke="#333" stroke-width="2.5"/>
                  <path d="M13 20h14M20 13v14" stroke="#333" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Lavadoras de ultrasonido.
              </li>
              <li>
                <svg class="icon-generic" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="20" cy="20" r="18" stroke="#333" stroke-width="2.5"/>
                  <path d="M13 20h14M20 13v14" stroke="#333" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Sistemas de medición de longitud y Mini cámaras.
              </li>
              <li>
                <svg class="icon-generic" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="20" cy="20" r="18" stroke="#333" stroke-width="2.5"/>
                  <path d="M13 20h14M20 13v14" stroke="#333" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Pulidores automáticos.
              </li>
              <li>
                <svg class="icon-generic" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="20" cy="20" r="18" stroke="#333" stroke-width="2.5"/>
                  <path d="M13 20h14M20 13v14" stroke="#333" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Sistemas de almacenamiento.
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 4: SISTEMA IH-TMS ════════════ -->
    <section class="section section--shaded">
      <div class="section__inner">
        <h2 class="section-title">Control Total con el Sistema IH-TMS.</h2>
        <p class="section-text">
          Una gestión eficaz de herramientas garantiza que sus herramientas funcionen de forma óptima durante todo su ciclo de vida.
        </p>

        <div class="highlight-box">
          <!-- Ícono genérico: checklist / cumplimiento -->
          <svg class="icon-generic" style="margin-top:0.15rem; flex-shrink:0;" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="5" y="5" width="30" height="30" rx="3" stroke="#111" stroke-width="2.5"/>
            <path d="M12 14h16M12 20h16M12 26h10" stroke="#111" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <p>
            El sistema <strong>IH-TMS</strong> cumple con <strong>CFR 21 Parte 11</strong> e incorpora gestión documental y trazabilidad completa.
            Ayuda a reducir los tiempos de inactividad y mejora la productividad general de sus operaciones.
          </p>
        </div>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 5: CAPACITACIÓN Y SOPORTE ════════════ -->
    <section class="section">
      <div class="section__inner">
        <h2 class="section-title">Empodere a su Equipo de Producción.</h2>
        <p class="section-text">
          Contamos con programas de capacitación en diversas áreas de la tabletería, incluyendo:
        </p>

        <div class="training-topics">
          <span class="training-tag">Diseño de tabletas</span>
          <span class="training-tag">Montaje de punzones</span>
          <span class="training-tag">Solución de problemas de producción</span>
        </div>

        <a href="#" class="btn">Consultar Programas de Capacitación</a>
      </div>
    </section>

    <!-- ════════════ FOOTER ════════════ -->
    <footer id="contacto" style="background:#111; color:#eee; padding:3rem 2rem;">
      <div style="max-width:1100px; margin:0 auto; display:flex; flex-direction:column; gap:1.5rem;">

        <div>
          <div style="font-size:1.4rem; font-weight:800; letter-spacing:0.1em; color:#fff;">TECHNOPHARMED</div>
          <p style="font-size:0.95rem; color:#bbb; margin-top:0.25rem;">Compromiso, Respaldo e Innovación.</p>
        </div>

        <hr style="border:none; border-top:1px solid #333;" />

        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <div style="display:flex; align-items:center; gap:0.6rem; font-size:0.9rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z" stroke="#eee" stroke-width="2"/><circle cx="12" cy="9" r="2.5" stroke="#eee" stroke-width="2"/></svg>
            Carrera 3F Nº 32A - 13, Manizales - Colombia.
          </div>
          <div style="display:flex; align-items:center; gap:0.6rem; font-size:0.9rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="#eee" stroke-width="2"/></svg>
            (+57) 313 831 1426
          </div>
          <div style="display:flex; align-items:center; gap:0.6rem; font-size:0.9rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#eee" stroke-width="2"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke="#eee" stroke-width="2"/></svg>
            <a href="https://www.technopharmed.com" target="_blank" style="color:#eee;">www.technopharmed.com</a>
          </div>
        </div>

        <hr style="border:none; border-top:1px solid #333;" />

        <div style="font-size:0.85rem; line-height:1.8; color:#ccc;">
          <p><strong style="color:#fff;">Directorio de Soporte</strong></p>
          <p>Gerencia: Ing. Juan Quintero &nbsp;|&nbsp; <a href="mailto:gerencia@technopharmed.com" style="color:#bbb;">gerencia@technopharmed.com</a> &nbsp;|&nbsp; Tel: 313 831 1426</p>
          <p>Administrativo: Claudia Santa &nbsp;|&nbsp; <a href="mailto:administrativo@technopharmed.com" style="color:#bbb;">administrativo@technopharmed.com</a> &nbsp;|&nbsp; Tel: 313 627 36 94</p>
          <p>Asistencia: Laura Uribe &nbsp;|&nbsp; <a href="mailto:asistente@technopharmed.com" style="color:#bbb;">asistente@technopharmed.com</a> &nbsp;|&nbsp; Tel: 318 837 6804</p>
        </div>

      </div>
    </footer>

  </body>
</html>
