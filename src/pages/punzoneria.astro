  /* ──────────────────────────────────────────────────
     REUSED UTILITIES (col-cards, chips, highlight, CTA)
  ────────────────────────────────────────────────── */
  .col-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 1.5rem; }
