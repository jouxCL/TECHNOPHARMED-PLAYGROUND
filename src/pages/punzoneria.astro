    padding: .85rem 1.25rem;
    background: var(--md-surface); border-radius: var(--r-md);
    border: 1px solid var(--md-outline-variant); box-shadow: var(--el-1);
    transition: transform 300ms var(--ease-standard), box-shadow 300ms, background 300ms;
  }
  .step-item:hover { transform: translateX(6px); box-shadow: var(--el-2); background: var(--md-primary-container); }
  .step-item__num {
    font-size: 1.5rem; font-weight: 900; color: var(--md-primary);
    line-height: 1; min-width: 2.2rem; opacity: .65; flex-shrink: 0;
  }
  .step-item:hover .step-item__num { opacity: 1; }
  .step-item__title { font-size: .95rem; font-weight: 800; color: var(--md-on-surface); margin-bottom: .15rem; }
  .step-item__title em { font-style: normal; font-weight: 400; color: var(--md-on-surface-variant); font-size: .85rem; }
  .step-item__text  { font-size: .87rem; color: var(--md-on-surface-variant); line-height: 1.55; }

   /* Stagger delays para los 7 pasos */
   .stagger-6 { transition-delay: 480ms; }
   .stagger-7 { transition-delay: 560ms; }

   /* Punzón Corroido Animation (1:1 aspect ratio) */
   .punzon-corroido-container {
     width: 100%;
     display: flex;
     justify-content: center;
     align-items: center;
   }
   .punzon-corroido-wrapper {
     position: relative;
     width: 100%;
     max-width: 300px;
   }
   .punzon-corroido-badge {
     position: absolute;
     top: 50%;
     left: 50%;
     transform: translate(-50%, -50%);
     z-index: 2;
     display: inline-flex;
     align-items: center;
     font-size: .68rem;
     font-weight: 700;
     letter-spacing: .1em;
     text-transform: uppercase;
     padding: .35rem .85rem;
     border-radius: var(--r-full);
     background: rgba(179,38,30);
