     align-items: center;
   }
   .punzon-solucion-wrapper {
     position: relative;
     width: 100%;
     max-width: 300px;
   }
   .punzon-solucion-badge {
     position: absolute;
     top: 50%;
     left: 50%;
     transform: translate(-50%, -50%);
     z-index: 2;
     display: inline-flex;
     align-items: center;
