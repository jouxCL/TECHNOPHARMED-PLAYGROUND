    animation: globalGlow 4s ease-in-out infinite;
  }
  .highlight-banner__title { font-size: 1.05rem; font-weight: 800; color: var(--md-on-primary-container); margin-bottom: .35rem; }
  .highlight-banner__body  { font-size: .92rem; color: var(--md-on-primary-container); line-height: 1.65; opacity: .85; }

  .blue-cta { text-align: center; }
  .blue-cta__title { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; color: #fff; margin-bottom: .75rem; }
  .blue-cta__body  { font-size: .98rem; color: rgba(255,255,255,.78); line-height: 1.7; margin-bottom: 1.5rem; max-width: 560px; margin-left: auto; margin-right: auto; }
  .blue-cta md-filled-button {
    --md-filled-button-container-color: #fff;
    --md-filled-button-hover-container-color: #F0F4F8;
    --md-filled-button-label-text-color: var(--md-primary);
    --md-filled-button-hover-label-text-color: var(--md-primary);
    --md-filled-button-leading-space: 2.5rem;
    --md-filled-button-trailing-space: 2.5rem;
  }

  /* ──────────────────────────────────────────────────
     GLOBAL KEYFRAMES (reutilizados del Layout)
  ────────────────────────────────────────────────── */
  @keyframes globalGlow  { 0%,100%{box-shadow:var(--el-1)} 50%{box-shadow:0 4px 8px rgba(0,82,154,.22)} }
  @keyframes borderPulse { 0%,100%{border-left-color:var(--md-primary)} 50%{border-left-color:rgba(0,82,154,.5)} }
</style>

<script is:inline>
  /* ══ INTERACTIVE DIAGRAM SYNC ══ */
  document.addEventListener('DOMContentLoaded', () => {
    const parts = document.querySelectorAll('.punzon-part');
    const boxes = document.querySelectorAll('.keypoint');

    const syncHover = (partId, active) => {
      const part = document.querySelector(`.punzon-part[data-part="${partId}"]`);
      const box = document.querySelector(`.keypoint[data-part="${partId}"]`);
      
      if (active) {
        part?.classList.add('punzon-part--active');
        box?.classList.add('keypoint--active');
      } else {
        parts.forEach(p => p.classList.remove('punzon-part--active'));
        boxes.forEach(b => b.classList.remove('keypoint--active'));
      }
    };

    parts.forEach(p => {
      p.addEventListener('mouseenter', () => syncHover(p.dataset.part, true));
      p.addEventListener('mouseleave', () => syncHover(p.dataset.part, false));
    });

    boxes.forEach(b => {
      b.addEventListener('mouseenter', () => syncHover(b.dataset.part, true));
      b.addEventListener('mouseleave', () => syncHover(b.dataset.part, false));
    });

    /* ══ PHARMACARE DECK NAVIGATION (SWIPE & DYNAMIC HEIGHT) ══ */
    const deckContainer = document.getElementById('pharmacare-carousel');
    const cards = document.querySelectorAll('.pharmacare-card');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');

    if (deckContainer && cards.length > 0 && btnPrev && btnNext) {
      let currentIndex = 0;

      // 1. DYNAMIC HEIGHT CALCULATION
      const syncDeckHeight = () => {
        let maxHeight = 0;
        
        // Temporarily prepare cards for measurement without disrupting layout
        cards.forEach(card => {
          card.style.transition = 'none'; // Prevent animation glitch
          card.style.height = 'auto'; // Let it expand to content naturally
        });

        // Measure
        cards.forEach(card => {
          if (card.scrollHeight > maxHeight) {
            maxHeight = card.scrollHeight;
          }
        });

        // Apply max height and restore fixed height so flex space-between works correctly inside
        deckContainer.style.height = `${maxHeight + 60}px`; // Add leeway for deck shadow/offset stack
        cards.forEach(card => {
          card.style.height = `${maxHeight}px`; 
          // Re-enable transitions on the next frame
          requestAnimationFrame(() => {
            card.style.transition = ''; 
          });
        });
      };

      // 2. DECK UPDATE LOGIC
      const updateDeck = () => {
        cards.forEach((card, index) => {
          card.classList.remove('pharmacare-card--active', 'pharmacare-card--next-1', 'pharmacare-card--next-2');
          
          if (index === currentIndex) {
            card.classList.add('pharmacare-card--active');
          } else if (index === currentIndex + 1) {
            card.classList.add('pharmacare-card--next-1');
          } else if (index === currentIndex + 2) {
            card.classList.add('pharmacare-card--next-2');
          }
        });

        // Update button states
        btnPrev.style.opacity = currentIndex === 0 ? '0.3' : '1';
        btnPrev.style.pointerEvents = currentIndex === 0 ? 'none' : 'auto';

        btnNext.style.opacity = currentIndex === cards.length - 1 ? '0.3' : '1';
        btnNext.style.pointerEvents = currentIndex === cards.length - 1 ? 'none' : 'auto';
      };

      // Button listeners
      btnPrev.addEventListener('click', () => {
        if (currentIndex > 0) {
          currentIndex--;
          updateDeck();
        }
      });

      btnNext.addEventListener('click', () => {
        if (currentIndex < cards.length - 1) {
          currentIndex++;
          updateDeck();
        }
      });

      // 3. FOOTER LINKS INTERACTION
      const nextLabels = document.querySelectorAll('.pharmacare-card__next');
      nextLabels.forEach(label => {
        label.addEventListener('click', () => {
          if (currentIndex < cards.length - 1) {
            currentIndex++;
            updateDeck();
          }
        });
      });
      
      // 4. SWIPE LOGIC
      let touchStartX = 0;
      let touchEndX = 0;

      deckContainer.addEventListener('touchstart', e => {
        touchStartX = e.changedTouches[0].screenX;
      }, {passive: true});

      deckContainer.addEventListener('touchend', e => {
        touchEndX = e.changedTouches[0].screenX;
        handleSwipe();
      }, {passive: true});

      const handleSwipe = () => {
        const threshold = 40; // minimum pixels to be considered a swipe
        const swipedLeft = touchStartX - touchEndX > threshold;
        const swipedRight = touchEndX - touchStartX > threshold;

        if (swipedLeft && currentIndex < cards.length - 1) {
          currentIndex++;
          updateDeck();
        } else if (swipedRight && currentIndex > 0) {
          currentIndex--;
          updateDeck();
        }
      };

      // Initialize
      window.addEventListener('load', syncDeckHeight);
      window.addEventListener('resize', syncDeckHeight);
      
      // Run immediately in case load already fired
      syncDeckHeight();
      updateDeck();
    }
  });
</script>
