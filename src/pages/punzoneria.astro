     box-shadow: var(--el-1);
     transition: transform 500ms var(--ease-emphasized), opacity 500ms, box-shadow 500ms, border-color 300ms;
     cursor: default;
     overflow: hidden;
     opacity: 0;
     pointer-events: none;
     transform: translateY(40px) scale(0.9);
     z-index: 1;
   }
   
   /* Active Card State */
   .pharmacare-card--active {
     opacity: 1;
     pointer-events: auto;
     transform: translateY(0) scale(1);
     z-index: 10;
     box-shadow: var(--el-2);
   }
   /* The card immediately behind the active one (Depth illusion) */
   .pharmacare-card--next-1 {
     opacity: 0.6;
     transform: translateY(15px) scale(0.95);
     z-index: 9;
     pointer-events: none;
   }
   .pharmacare-card--next-2 {
