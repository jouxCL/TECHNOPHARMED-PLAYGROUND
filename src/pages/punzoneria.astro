<script is:inline>
  /* ══ INTERACTIVE DIAGRAM SYNC ══ */
  document.addEventListener('DOMContentLoaded', () => {
    const parts = document.querySelectorAll('.punzon-part');
    const boxes = document.querySelectorAll('.keypoint');

    const syncHover = (partId, active) => {
      const part = document.querySelector(`.punzon-part[data-part="${partId}"]`);
      const box = document.querySelector(`.keypoint[data-part="${partId}"]`);
      
      if (active) {
        part?.classList.add('punzon-part--active');
        box?.classList.add('keypoint--active');
      } else {
        parts.forEach(p => p.classList.remove('punzon-part--active'));
        boxes.forEach(b => b.classList.remove('keypoint--active'));
      }
    };

    parts.forEach(p => {
      p.addEventListener('mouseenter', () => syncHover(p.dataset.part, true));
      p.addEventListener('mouseleave', () => syncHover(p.dataset.part, false));
    });

    boxes.forEach(b => {
      b.addEventListener('mouseenter', () => syncHover(b.dataset.part, true));
      b.addEventListener('mouseleave', () => syncHover(b.dataset.part, false));
    });
  });
</script>
