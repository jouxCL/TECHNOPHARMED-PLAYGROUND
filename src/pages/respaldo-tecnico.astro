<script>
  /* ══ SVG TREND LINE draw on scroll ══ */
  const trendLine = document.querySelector<SVGPolylineElement>('.rt-trend-line');
  if (trendLine) {
    const len = trendLine.getTotalLength?.() ?? 400;
    trendLine.style.strokeDasharray  = String(len);
    trendLine.style.strokeDashoffset = String(len);
    const trendObs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        trendLine.style.transition = 'stroke-dashoffset 1.8s cubic-bezier(0.4,0,0.2,1)';
        trendLine.style.strokeDashoffset = '0';
        trendObs.disconnect();
      }
    }, { threshold: 0.4 });
    trendObs.observe(trendLine);
  }

  /* ══ STEP TRACKER — stagger entrance ══ */
  const stepItems = document.querySelectorAll<HTMLElement>('.rt-step-item');
  const stepObs = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      stepItems.forEach((item, i) => {
        setTimeout(() => item.classList.add('step-visible'), i * 80);
      });
      stepObs.disconnect();
    }
  }, { threshold: 0.2 });
  if (stepItems.length) stepObs.observe(stepItems[0].closest('ol') as Element);
</script>


