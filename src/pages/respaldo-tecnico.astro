---
import Navbar from '../components/Navbar.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Respaldo Técnico – Technopharmed</title>
    <style>
      /* ─── RESET MINIMAL ─── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, Helvetica, sans-serif; color: #111; background: #fff; }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }

      /* ─── PLACEHOLDER ─── */
      .img-placeholder {
        width: 100%;
        background-image: repeating-conic-gradient(#000 0% 25%, #ff00ff 0% 50%);
        background-size: 32px 32px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 0.75rem; letter-spacing: 0.05em;
        text-shadow: 0 1px 3px #000;
      }
      .img-placeholder--hero   { aspect-ratio: 21 / 9; }
      .img-placeholder--medium { aspect-ratio: 4 / 3; }

      /* ─── BOTÓN ─── */
      .btn {
        display: inline-block;
        padding: 0.6rem 1.4rem;
        border: 2px solid #333;
        cursor: pointer; font-size: 0.9rem; font-weight: bold;
        background: transparent;
      }

      /* ─── SECCIÓN ─── */
      .section { padding: 3rem 2rem; }
      .section--shaded { background: #f8f8f8; }
      .section__inner { max-width: 1100px; margin: 0 auto; }
      .section-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 1.25rem; }
      .section-text  { font-size: 0.95rem; line-height: 1.65; color: #333; margin-bottom: 0.75rem; }

      /* ─── HERO ─── */
      .hero { position: relative; overflow: hidden; }
      .hero__overlay {
        position: absolute; inset: 0;
        background: rgba(0,0,0,0.52);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; color: #fff; padding: 2rem; gap: 1rem;
      }
      .hero__title    { font-size: clamp(1.4rem, 3.5vw, 2.5rem); font-weight: 800; max-width: 800px; }
      .hero__subtitle { font-size: clamp(0.9rem, 1.7vw, 1.1rem); max-width: 700px; line-height: 1.6; }

      /* ─── PUNTOS CLAVE ─── */
      .key-points {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.25rem;
        margin-top: 1.5rem;
      }
      .key-card {
        border: 1px solid #ccc;
        padding: 1.1rem 1.25rem;
        display: flex; gap: 0.9rem; align-items: flex-start;
      }
      .key-card p { font-size: 0.9rem; line-height: 1.6; color: #333; }

      /* ─── ÁREAS / BENEFICIOS ─── */
      .area-list {
        list-style: none; padding: 0; margin: 0.85rem 0;
        display: flex; flex-direction: column; gap: 0.55rem;
      }
      .area-list li {
        display: flex; gap: 0.6rem; align-items: flex-start;
        font-size: 0.9rem; line-height: 1.55; color: #333;
      }
      .area-list li::before {
        content: "▸"; color: #444; flex-shrink: 0; margin-top: 0.05rem;
      }

      /* ─── DOS COLUMNAS ─── */
      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem; align-items: start;
        margin-top: 1.25rem;
      }
      @media (max-width: 700px) { .two-col { grid-template-columns: 1fr; } }
    </style>
  </head>

  <body>

    <!-- ════════════ NAVBAR ════════════ -->
    <Navbar />

    <!-- ════════════ HERO ════════════ -->
    <section class="hero">
      <div class="img-placeholder img-placeholder--hero"><span>IMAGEN PLACEHOLDER</span></div>
      <div class="hero__overlay">
        <h1 class="hero__title">#1 en Satisfacción del Cliente.</h1>
        <p class="hero__subtitle">
          Nuestra filosofía enfocada al servicio técnico y asesoría personalizada nos permite ofrecer soluciones adaptadas de manera exitosa para maximizar la productividad de nuestros clientes.
        </p>
        <p class="hero__subtitle" style="font-style: italic; font-size: clamp(0.82rem, 1.4vw, 0.97rem); color: #ddd;">
          Nuestra filosofía de servicio, la experiencia y la alianza estratégica con reconocidos fabricantes a nivel mundial son nuestra mejor carta de garantía.
        </p>
        <a href="#contacto" class="btn" style="color:#fff; border-color:#fff;">Solicitar Asistencia Técnica</a>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 1: SOPORTE Y AUTOMATIZACIÓN ════════════ -->
    <section class="section">
      <div class="section__inner">
        <h2 class="section-title">Ingeniería y Asistencia 24 Horas.</h2>
        <p class="section-text">
          Contamos con expertos técnicamente capacitados y una gama de equipos de última generación.
        </p>

        <div class="key-points">

          <div class="key-card">
            <!-- Ícono: reloj / 24h -->
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" flex-shrink="0" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="17" stroke="#333" stroke-width="2.5"/>
              <path d="M20 11v9l6 6" stroke="#333" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
            <p>Soporte técnico las <strong>24 horas</strong> para garantizar la continuidad de sus operaciones.</p>
          </div>

          <div class="key-card">
            <!-- Ícono: persona / asesoría -->
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="14" r="7" stroke="#333" stroke-width="2.5"/>
              <path d="M6 36c0-7.732 6.268-14 14-14s14 6.268 14 14" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            <p><strong>Venta técnica personalizada</strong> para asegurar que adquiera exactamente lo que su proceso necesita.</p>
          </div>

          <div class="key-card">
            <!-- Ícono: engranaje / ingeniería -->
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="6" stroke="#333" stroke-width="2.5"/>
              <path d="M20 4v4M20 32v4M4 20h4M32 20h4M8.34 8.34l2.83 2.83M28.83 28.83l2.83 2.83M8.34 31.66l2.83-2.83M28.83 11.17l2.83-2.83" stroke="#333" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
            <p>Ingeniería innovadora en <strong>automatización y reconstrucción</strong> de maquinaria y equipo.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 2: CAPACITACIÓN EN PLANTA ════════════ -->
    <section class="section section--shaded">
      <div class="section__inner">
        <h2 class="section-title">Empodere a su Personal.</h2>

        <div class="two-col">
          <div class="img-placeholder img-placeholder--medium"><span>IMAGEN PLACEHOLDER</span></div>
          <div>
            <p class="section-text">
              Ofrecemos programas de capacitación completos para nuestros clientes <strong>en sus instalaciones</strong>.
            </p>
            <ul class="area-list">
              <li>Programas de capacitación en diversas áreas de la tabletería.</li>
              <li>Instrucción detallada en diseño de tabletas y montaje de punzones.</li>
              <li>Capacitación enfocada en la solución de problemas de producción de tabletas.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 3: MANTENIMIENTO PREVENTIVO ════════════ -->
    <section class="section">
      <div class="section__inner">
        <h2 class="section-title">Optimización y Vida Útil del Herramental.</h2>

        <div class="two-col">
          <div>
            <p class="section-text">
              Contamos con un programa de <strong>Mantenimiento para Punzones</strong> basado en Los 7 Pasos del Mantenimiento.
            </p>
            <ul class="area-list">
              <li>Reduce el <strong>tiempo de inactividad</strong> de la máquina tableteadora.</li>
              <li>Minimiza los problemas de compresión de manera efectiva.</li>
              <li>Mejora la <strong>vida útil y el rendimiento óptimo</strong> de sus punzones.</li>
            </ul>
          </div>
          <div class="img-placeholder img-placeholder--medium"><span>IMAGEN PLACEHOLDER</span></div>
        </div>
      </div>
    </section>

    <!-- ════════════ FOOTER ════════════ -->
    <footer id="contacto" style="background:#111; color:#eee; padding:3rem 2rem;">
      <div style="max-width:1100px; margin:0 auto; display:flex; flex-direction:column; gap:1.5rem;">

        <div>
          <div style="font-size:1.4rem; font-weight:800; letter-spacing:0.1em; color:#fff;">TECHNOPHARMED</div>
          <p style="font-size:0.95rem; color:#bbb; margin-top:0.25rem;">Compromiso, Respaldo e Innovación.</p>
        </div>

        <hr style="border:none; border-top:1px solid #333;" />

        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <div style="display:flex; align-items:center; gap:0.6rem; font-size:0.9rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z" stroke="#eee" stroke-width="2"/><circle cx="12" cy="9" r="2.5" stroke="#eee" stroke-width="2"/></svg>
            Carrera 3F Nº 32A - 13, Manizales - Colombia.
          </div>
          <div style="display:flex; align-items:center; gap:0.6rem; font-size:0.9rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="#eee" stroke-width="2"/></svg>
            (+57) 313 831 1426
          </div>
          <div style="display:flex; align-items:center; gap:0.6rem; font-size:0.9rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#eee" stroke-width="2"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke="#eee" stroke-width="2"/></svg>
            <a href="https://www.technopharmed.com" target="_blank" style="color:#eee;">www.technopharmed.com</a>
          </div>
        </div>

        <hr style="border:none; border-top:1px solid #333;" />

        <div style="font-size:0.85rem; line-height:1.8; color:#ccc;">
          <p><strong style="color:#fff;">Directorio de Soporte</strong></p>
          <p>Gerencia: Ing. Juan Quintero &nbsp;|&nbsp; <a href="mailto:gerencia@technopharmed.com" style="color:#bbb;">gerencia@technopharmed.com</a> &nbsp;|&nbsp; Tel: 313 831 1426</p>
          <p>Administrativo: Claudia Santa &nbsp;|&nbsp; <a href="mailto:administrativo@technopharmed.com" style="color:#bbb;">administrativo@technopharmed.com</a> &nbsp;|&nbsp; Tel: 313 627 36 94</p>
          <p>Asistencia: Laura Uribe &nbsp;|&nbsp; <a href="mailto:asistente@technopharmed.com" style="color:#bbb;">asistente@technopharmed.com</a> &nbsp;|&nbsp; Tel: 318 837 6804</p>
        </div>

      </div>
    </footer>

  </body>
</html>
