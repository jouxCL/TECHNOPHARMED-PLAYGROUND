---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contáctenos – Technopharmed" description="Comuníquese con el equipo de Technopharmed. Asesoría técnica y comercial disponible.">

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  HERO EXCLUSIVO DE CONTACTO                           -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="ct-hero" aria-label="Contáctenos">
    <!-- Fondo animado con gradiente pulsante -->
    <div class="ct-hero__bg" aria-hidden="true">
      <div class="ct-bg-orb ct-bg-orb--1"></div>
      <div class="ct-bg-orb ct-bg-orb--2"></div>
      <div class="ct-bg-orb ct-bg-orb--3"></div>
      <div class="ct-grid" aria-hidden="true"></div>
    </div>

    <!-- Contenido hero -->
    <div class="ct-hero__content">
      <span class="ct-eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 013 3.18 2 2 0 015 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L9.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Comuníquese con Nosotros
      </span>

      <h1 class="ct-hero__title">
        Estamos listos para<br/>
        <span class="ct-gradient-text">servirle.</span>
      </h1>

      <p class="ct-hero__subtitle">
        Nuestro equipo de expertos técnicos y comerciales está disponible para brindarle la asesoría que su empresa necesita. Cuéntenos su proyecto.
      </p>

      <!-- Scroll indicator -->
      <div class="ct-scroll-hint" aria-hidden="true">
        <div class="ct-scroll-hint__dot"></div>
      </div>
    </div>

    <!-- Decoraciones geométricas -->
    <div class="ct-hero__deco" aria-hidden="true">
      <div class="ct-deco-ring ct-deco-ring--lg"></div>
      <div class="ct-deco-ring ct-deco-ring--sm"></div>
      <div class="ct-deco-line ct-deco-line--v"></div>
      <div class="ct-deco-line ct-deco-line--h"></div>
    </div>

    <!-- Wave inferior -->
    <div class="ct-hero__wave">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 72" preserveAspectRatio="none" style="width: 100%; height: 72px; display: block;">
        <path fill="var(--md-bg,#F8F9FC)" d="M0,36 C480,72 960,0 1440,36 L1440,72 L0,72 Z"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  FORMULARIO + DIRECTORIO                              -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="ct-main">
    <div class="ct-inner">

      <!-- ── Columna izquierda: Formulario ── -->
      <div class="ct-form-col reveal">
        <p class="pg-eyebrow">Formulario de Contacto</p>
        <h2 class="ct-section-title">Envíenos un Mensaje</h2>
        <p class="ct-section-body">Diligenciemos el formulario y uno de nuestros asesores se comunicará con usted en las próximas 24 horas hábiles.</p>

        <form id="contact-form" class="ct-form" novalidate>
          <!-- Nombre -->
          <div class="ct-field" id="field-name">
            <label class="ct-label" for="f-name">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2"/></svg>
              Nombre completo
            </label>
            <input id="f-name" name="nombre" type="text" class="ct-input" placeholder="Ej. Juan Pérez" autocomplete="name" required />
            <span class="ct-field__error">Por favor ingrese su nombre.</span>
          </div>

          <!-- Correo -->
          <div class="ct-field" id="field-email">
            <label class="ct-label" for="f-email">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="2"/><path d="M2 8l10 7 10-7" stroke="currentColor" stroke-width="2"/></svg>
              Correo electrónico
            </label>
            <input id="f-email" name="correo" type="email" class="ct-input" placeholder="correo@empresa.net" autocomplete="email" required />
            <span class="ct-field__error">Ingrese un correo válido.</span>
          </div>

          <!-- Teléfono -->
          <div class="ct-field" id="field-phone">
            <label class="ct-label" for="f-phone">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="currentColor" stroke-width="2"/></svg>
              Teléfono / Celular
            </label>
            <input id="f-phone" name="telefono" type="tel" class="ct-input" placeholder="+57 300 000 0000" autocomplete="tel" />
          </div>

          <!-- Nota -->
          <div class="ct-field" id="field-note">
            <label class="ct-label" for="f-note">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Nota / Descripción del proyecto
            </label>
            <textarea id="f-note" name="nota" class="ct-input ct-textarea" placeholder="Cuéntenos sobre su proceso, tipo de máquina de interés, capacidad requerida…" rows="5" required></textarea>
            <span class="ct-field__error">Por favor describa su consulta.</span>
          </div>

          <!-- Submit -->
          <div class="ct-form__actions">
            <button type="submit" id="ct-submit" class="ct-btn-submit">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/></svg>
              Enviar Mensaje
            </button>
            <p class="ct-disclaimer">* Al enviar, acepta que nos comuniquemos con usted para brindarle atención técnica y comercial.</p>
          </div>

           <!-- Estado enviado -->
          <div id="ct-success" class="ct-success" hidden>
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#1D6B3A" stroke-width="2"/><path d="M7 12l4 4 6-6" stroke="#1D6B3A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div>
              <p class="ct-success__title">¡Mensaje enviado!</p>
              <p class="ct-success__body">Le responderemos pronto. Gracias por contactarnos.</p>
            </div>
          </div>

          <!-- Estado error -->
          <div id="ct-error" class="ct-error" hidden>
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#B91C1C" stroke-width="2"/><path d="M15 9l-6 6M9 9l6 6" stroke="#B91C1C" stroke-width="2.5" stroke-linecap="round"/></svg>
            <div>
              <p class="ct-error__title" id="error-title">Error al enviar</p>
              <p class="ct-error__body" id="error-message">Por favor intente de nuevo más tarde.</p>
            </div>
          </div>
        </form>
      </div>

      <!-- ── Columna derecha: Info de contacto ── -->
      <div class="ct-info-col">

        <!-- Directorio -->
        <div class="ct-dir-card reveal stagger-1">
          <p class="pg-eyebrow">Directorio</p>
          <h3 class="ct-section-title" style="font-size:1.4rem;">Nuestro Equipo</h3>

          <div class="ct-person">
            <div class="ct-person__avatar">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <div>
              <p class="ct-person__role">Gerencia Técnica</p>
              <p class="ct-person__name">Juan Quintero</p>
              <a class="ct-person__link" href="mailto:gerencia@technopharmed.net">gerencia@technopharmed.net</a>
              <a class="ct-person__link" href="tel:+573138311426">313 831 1426</a>
            </div>
          </div>
          <div class="ct-divider"></div>
          <div class="ct-person">
            <div class="ct-person__avatar">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <div>
              <p class="ct-person__role">Gerencia Administrativa</p>
              <p class="ct-person__name">Claudia Santa</p>
              <a class="ct-person__link" href="mailto:administrativo@technopharmed.net">administrativo@technopharmed.net</a>
              <a class="ct-person__link" href="tel:+573136273694">313 627 36 94</a>
            </div>
          </div>

          <!-- Botón Canales de Atención -->
          <button class="ct-channels-btn" id="btn-channels" aria-expanded="false" aria-controls="channels-modal">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.86 9.81 19.79 19.79 0 01.77 1.22 2 2 0 012.76.03h3a2 2 0 012 1.72c.13.97.37 1.93.7 2.85a2 2 0 01-.45 2.11L6.91 7.81a16 16 0 006.29 6.29l1.1-1.1a2 2 0 012.11-.45c.92.33 1.88.57 2.85.7A2 2 0 0122 16.92z"/></svg>
            Canales de Atención
            <svg class="ct-channels-btn__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
        </div>

        <!-- Sede -->
        <div class="ct-sede-card reveal stagger-2">
          <p class="pg-eyebrow">Ubicación</p>
          <h3 class="ct-section-title" style="font-size:1.4rem;">Nuestra Sede</h3>
          
          <div class="ct-sede-rows">
            <div class="ct-sede-row">
              <div class="ct-sede-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="2"/></svg>
              </div>
              <span>CALLE 62 No 23 - 61 OFICINA 302 EDIFICIO TORRE PLAZA 62 - PALOGRANDE,<br/>Manizales, Caldas – Colombia</span>
            </div>
            <div class="ct-sede-row">
              <div class="ct-sede-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="currentColor" stroke-width="2"/></svg>
              </div>
              <a href="tel:+573138311426">(+57) 313 831 1426</a>
            </div>
            <div class="ct-sede-row">
              <div class="ct-sede-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke="currentColor" stroke-width="2"/></svg>
              </div>
              <a href="https://www.technopharmed.com.co" target="_blank" rel="noopener">www.technopharmed.com.co</a>
            </div>
          </div>

          <!-- Mapa -->
          <div class="ct-map">
            <iframe
              title="Ubicación Technopharmed – Manizales"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3974.277588147998!2d-75.4875113!3d5.0586877999999995!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e47657dd1b09f01%3A0x72a6f4f76de8888a!2sCl.%2062%20%2323-61%2C%20Manizales%2C%20Caldas!5e0!3m2!1ses!2sco!4v1775834973933!5m2!1ses!2sco"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>

      </div><!-- /ct-info-col -->
    </div><!-- /ct-inner -->
  </section>

  <!-- ═══ MODAL: CANALES DE ATENCIÓN ═══ -->
  <div id="channels-modal" class="ct-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="modal-title" hidden>
    <div class="ct-modal" id="channels-modal-panel">

      <div class="ct-modal__header">
        <div class="ct-modal__header-left">
          <div class="ct-modal__icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.86 9.81 19.79 19.79 0 01.77 1.22 2 2 0 012.76.03h3a2 2 0 012 1.72c.13.97.37 1.93.7 2.85a2 2 0 01-.45 2.11L6.91 7.81a16 16 0 006.29 6.29l1.1-1.1a2 2 0 012.11-.45c.92.33 1.88.57 2.85.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <p class="ct-modal__eyebrow">Guía de Contacto</p>
            <h2 id="modal-title" class="ct-modal__title">Canales de Atención</h2>
          </div>
        </div>
        <button class="ct-modal__close" id="btn-channels-close" aria-label="Cerrar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <p class="ct-modal__subtitle">Dirija su solicitud al correo correspondiente según el tipo de gestión.</p>

      <div class="ct-modal__channels">

        <!-- Canal 1: Gerencia Técnica -->
        <div class="ct-channel-card">
          <div class="ct-channel-card__top">
            <div class="ct-channel-card__avatar" style="background: #D1E4FF; color: #00529A;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
            </div>
            <div>
              <p class="ct-channel-card__role">Gerencia Técnica</p>
              <a class="ct-channel-card__email" href="mailto:gerencia@technopharmed.net">gerencia@technopharmed.net</a>
            </div>
          </div>
          <p class="ct-channel-card__area-label">Dirección / Soporte Técnico</p>
          <div class="ct-channel-card__cols">
            <div class="ct-channel-col">
              <p class="ct-channel-col__title">Actualmente Atiende</p>
              <ul class="ct-channel-list">
                <li>Técnica y soporte</li>
                <li>Comercial</li>
                <li>Requerimientos</li>
                <li>Órdenes de Compra</li>
                <li>Planos</li>
              </ul>
            </div>
            <div class="ct-channel-col">
              <p class="ct-channel-col__title">También Puede Atender</p>
              <ul class="ct-channel-list">
                <li>Evaluación técnica de proyectos</li>
                <li>Aprobación de especificaciones</li>
                <li>Validación de planos y diseños</li>
                <li>Coordinación con fabricantes</li>
                <li>Garantías técnicas</li>
                <li>Desarrollo de proyectos</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Canal 2: Gerencia Administrativa -->
        <div class="ct-channel-card">
          <div class="ct-channel-card__top">
            <div class="ct-channel-card__avatar" style="background: #D3E5F5; color: #4F6680;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
            </div>
            <div>
              <p class="ct-channel-card__role">Gerencia Administrativa</p>
              <a class="ct-channel-card__email" href="mailto:administrativo@technopharmed.net">administrativo@technopharmed.net</a>
            </div>
          </div>
          <p class="ct-channel-card__area-label">Gestión Comercial y Operativa</p>
          <div class="ct-channel-card__cols">
            <div class="ct-channel-col">
              <p class="ct-channel-col__title">Actualmente Atiende</p>
              <ul class="ct-channel-list">
                <li>Comercial</li>
                <li>Requerimientos</li>
                <li>Cotizaciones</li>
                <li>Cartera</li>
                <li>Órdenes de Compra</li>
                <li>Importaciones</li>
                <li>Facturación Electrónica</li>
              </ul>
            </div>
            <div class="ct-channel-col">
              <p class="ct-channel-col__title">También Puede Atender</p>
              <ul class="ct-channel-list">
                <li>Seguimiento de cotizaciones</li>
                <li>Registro de pedidos</li>
                <li>Coordinación logística de entregas</li>
                <li>Gestión documental comercial</li>
                <li>Actualización de información de clientes</li>
                <li>Coordinación de despachos</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Canal 3: Gestión Financiera -->
        <div class="ct-channel-card">
          <div class="ct-channel-card__top">
            <div class="ct-channel-card__avatar" style="background: #EEE0FF; color: #685F78;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
            </div>
            <div>
              <p class="ct-channel-card__role">Gestión Financiera</p>
              <a class="ct-channel-card__email" href="mailto:gestion@technopharmed.net">gestion@technopharmed.net</a>
            </div>
          </div>
          <p class="ct-channel-card__area-label">Gestión Financiera y Documental</p>
          <div class="ct-channel-card__cols">
            <div class="ct-channel-col">
              <p class="ct-channel-col__title">Actualmente Atiende</p>
              <ul class="ct-channel-list">
                <li>Tesorería</li>
                <li>Cartera</li>
                <li>Certificados</li>
                <li>Facturación Electrónica</li>
                <li>Envíos</li>
                <li>Documentación general</li>
              </ul>
            </div>
            <div class="ct-channel-col">
              <p class="ct-channel-col__title">También Puede Atender</p>
              <ul class="ct-channel-list">
                <li>Confirmación de pagos</li>
                <li>Estados de cuenta</li>
                <li>Conciliaciones financieras</li>
                <li>Programación de pagos</li>
                <li>Soportes de pago</li>
                <li>Gestión de anticipos</li>
                <li>Control de crédito</li>
              </ul>
            </div>
          </div>
        </div>

      </div><!-- /ct-modal__channels -->
    </div><!-- /ct-modal -->
  </div><!-- /ct-modal-backdrop -->

</Layout>

<style is:global>
  /* ══════════════════════════════════
     HERO
  ══════════════════════════════════ */
  .ct-hero {
    position: relative;
    min-height: 55vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #001D36;
  }

  /* Fondo con orbs */
  .ct-hero__bg { position: absolute; inset: 0; z-index: 0; }

  .ct-bg-orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); pointer-events: none;
    animation: orbPulse 8s ease-in-out infinite;
  }
  .ct-bg-orb--1 { width:500px; height:500px; background:rgba(0,82,154,.45); top:-200px; left:-100px; }
  .ct-bg-orb--2 { width:380px; height:380px; background:rgba(0,53,112,.35); bottom:-120px; right:-80px; animation-delay:2.5s; }
  .ct-bg-orb--3 { width:220px; height:220px; background:rgba(158,202,255,.08); top:30%; left:40%; animation-delay:5s; }

  @keyframes orbPulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.12);opacity:.75} }

  /* Grilla de puntos */
  .ct-grid {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(158,202,255,.14) 1.5px, transparent 1.5px);
    background-size: 30px 30px;
    opacity: .4;
  }

  /* Decoraciones geométricas */
  .ct-hero__deco { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .ct-deco-ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(158,202,255,.1);
  }
  .ct-deco-ring--lg { width:600px; height:600px; top:-250px; right:-200px; animation: slowSpin 90s linear infinite; }
  .ct-deco-ring--sm { width:220px; height:220px; bottom:-80px; left:12%; animation: slowSpin 50s linear infinite reverse; }
  .ct-deco-line {
    position: absolute;
    background: linear-gradient(transparent, rgba(158,202,255,.18), transparent);
  }
  .ct-deco-line--v { width:1px; height:200px; right:14%; top:10%; animation: lineFade 4s ease-in-out infinite; }
  .ct-deco-line--h { height:1px; width:160px; left:8%; bottom:28%; animation: lineFade 4s ease-in-out infinite 1.8s; background: linear-gradient(to right, transparent, rgba(158,202,255,.18), transparent); }

  @keyframes slowSpin { to{ transform:rotate(360deg); } }
  @keyframes lineFade { 0%,100%{opacity:.2} 50%{opacity:1} }

  /* Contenido */
  .ct-hero__content {
    position: relative; z-index: 2;
    width: 100%; max-width: 720px;
    margin: 0 auto;
    padding: 6rem 2rem 5rem;
    text-align: center;
  }

  .ct-eyebrow {
    display: inline-flex; align-items: center; gap: .5rem;
