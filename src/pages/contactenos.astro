---
import Navbar from '../components/Navbar.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Contáctenos – Technopharmed</title>
    <style>
      /* ─── RESET MINIMAL ─── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, Helvetica, sans-serif; color: #111; background: #fff; }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }

      /* ─── PLACEHOLDER ─── */
      .img-placeholder {
        width: 100%;
        background-image: repeating-conic-gradient(#000 0% 25%, #ff00ff 0% 50%);
        background-size: 32px 32px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 0.75rem; letter-spacing: 0.05em;
        text-shadow: 0 1px 3px #000;
      }
      .img-placeholder--hero { aspect-ratio: 21 / 9; }

      /* ─── SECCIÓN ─── */
      .section { padding: 3rem 2rem; }
      .section--shaded { background: #f8f8f8; }
      .section__inner { max-width: 1100px; margin: 0 auto; }
      .section-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; }
      .section-text  { font-size: 0.95rem; line-height: 1.65; color: #333; }

      /* ─── HERO ─── */
      .hero { position: relative; overflow: hidden; }
      .hero__overlay {
        position: absolute; inset: 0;
        background: rgba(0,0,0,0.52);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; color: #fff; padding: 2rem; gap: 1rem;
      }
      .hero__title    { font-size: clamp(1.4rem, 3.5vw, 2.5rem); font-weight: 800; }
      .hero__subtitle { font-size: clamp(0.9rem, 1.7vw, 1.15rem); max-width: 650px; line-height: 1.6; }

      /* ─── DIRECTORIO DE CONTACTO ─── */
      .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
      }
      .contact-card {
        border: 1px solid #ccc;
        padding: 1.5rem;
        display: flex; flex-direction: column; gap: 0.65rem;
      }
      .contact-card__role {
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
        text-transform: uppercase; color: #666;
      }
      .contact-card__name { font-size: 1.1rem; font-weight: 700; }
      .contact-card__row {
        display: flex; align-items: center; gap: 0.55rem;
        font-size: 0.88rem; color: #333; line-height: 1.5;
      }
      .contact-card__row a { color: #0054a6; }
      .contact-card__row a:hover { text-decoration: underline; }

      /* ─── SECCIÓN SEDE / MAPA ─── */
      .location-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem; align-items: start;
      }
      @media (max-width: 700px) { .location-layout { grid-template-columns: 1fr; } }

      .location-info {
        display: flex; flex-direction: column; gap: 1rem;
      }
      .location-row {
        display: flex; align-items: flex-start; gap: 0.65rem;
        font-size: 0.95rem; line-height: 1.6; color: #333;
      }
      .location-row a { color: #0054a6; }
      .location-row a:hover { text-decoration: underline; }

      /* mapa iframe */
      .map-wrapper {
        width: 100%;
        aspect-ratio: 4 / 3;
        border: 1px solid #ccc;
        overflow: hidden;
      }
      .map-wrapper iframe {
        width: 100%; height: 100%; border: 0;
      }
    </style>
  </head>

  <body>

    <!-- ════════════ NAVBAR ════════════ -->
    <Navbar />

    <!-- ════════════ HERO ════════════ -->
    <section class="hero">
      <div class="img-placeholder img-placeholder--hero"><span>IMAGEN PLACEHOLDER</span></div>
      <div class="hero__overlay">
        <h1 class="hero__title">Estamos para Servirle.</h1>
        <p class="hero__subtitle">
          Contáctese con nuestro equipo de expertos. Estamos listos para brindarle la asesoría técnica y comercial que su empresa necesita.
        </p>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 1: DIRECTORIO DE CONTACTO ════════════ -->
    <section class="section">
      <div class="section__inner">
        <h2 class="section-title">Comuníquese con Nuestro Equipo.</h2>

        <div class="contact-grid">

          <!-- BLOQUE A: GERENCIA -->
          <div class="contact-card">
            <span class="contact-card__role">Gerente General</span>
            <span class="contact-card__name">Ing. Juan Quintero</span>

            <div class="contact-card__row">
              <!-- Ícono correo -->
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" flex-shrink="0"><rect x="2" y="4" width="20" height="16" rx="2" stroke="#555" stroke-width="2"/><path d="M2 8l10 7 10-7" stroke="#555" stroke-width="2"/></svg>
              <div>
                <a href="mailto:gerencia@technopharmed.com">gerencia@technopharmed.com</a><br/>
                <a href="mailto:gerencia@technopharmed.net">gerencia@technopharmed.net</a>
              </div>
            </div>

            <div class="contact-card__row">
              <!-- Ícono teléfono -->
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="#555" stroke-width="2"/></svg>
              <span>313 831 1426</span>
            </div>
          </div>

          <!-- BLOQUE B: ADMINISTRATIVO -->
          <div class="contact-card">
            <span class="contact-card__role">Administrativo</span>
            <span class="contact-card__name">Claudia Santa</span>

            <div class="contact-card__row">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" flex-shrink="0"><rect x="2" y="4" width="20" height="16" rx="2" stroke="#555" stroke-width="2"/><path d="M2 8l10 7 10-7" stroke="#555" stroke-width="2"/></svg>
              <a href="mailto:administrativo@technopharmed.net">administrativo@technopharmed.net</a>
            </div>

            <div class="contact-card__row">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="#555" stroke-width="2"/></svg>
              <span>313 627 36 94</span>
            </div>
          </div>

          <!-- BLOQUE C: ASISTENTE -->
          <div class="contact-card">
            <span class="contact-card__role">Asistente Técnica y Comercial</span>
            <span class="contact-card__name">Laura Uribe</span>

            <div class="contact-card__row">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" flex-shrink="0"><rect x="2" y="4" width="20" height="16" rx="2" stroke="#555" stroke-width="2"/><path d="M2 8l10 7 10-7" stroke="#555" stroke-width="2"/></svg>
              <a href="mailto:asistente@technopharmed.net">asistente@technopharmed.net</a>
            </div>

            <div class="contact-card__row">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="#555" stroke-width="2"/></svg>
              <span>318 837 6804</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ════════════ SECCIÓN 2: SEDE Y MAPA ════════════ -->
    <section class="section section--shaded">
      <div class="section__inner">
        <h2 class="section-title">Nuestra Sede.</h2>

        <div class="location-layout">

          <!-- INFO DE CONTACTO -->
          <div class="location-info">

            <div class="location-row">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" flex-shrink="0"><path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z" stroke="#333" stroke-width="2"/><circle cx="12" cy="9" r="2.5" stroke="#333" stroke-width="2"/></svg>
              <span>Carrera 3F Nº 32A - 13, Manizales - Colombia.</span>
            </div>

            <div class="location-row">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="#333" stroke-width="2"/></svg>
