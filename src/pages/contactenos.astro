          </div>

        </div>
      </div>
    </section>

    <!-- ════════════ FOOTER ════════════ -->
    <footer style="background:#111; color:#eee; padding:3rem 2rem;">
      <div style="max-width:1100px; margin:0 auto; display:flex; flex-direction:column; gap:1.5rem;">

        <div>
          <div style="font-size:1.4rem; font-weight:800; letter-spacing:0.1em; color:#fff;">TECHNOPHARMED</div>
