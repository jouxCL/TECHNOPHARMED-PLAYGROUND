            <div class="location-row">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#333" stroke-width="2"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke="#333" stroke-width="2"/></svg>
              <a href="https://www.technopharmed.com" target="_blank">www.technopharmed.com</a>
