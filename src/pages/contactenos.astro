    transition: box-shadow .2s, transform .2s;
  }
  .ct-channel-card:hover { box-shadow: var(--el-2); transform: translateY(-2px); }

  .ct-channel-card__top {
    display: flex; align-items: center; gap: .75rem; margin-bottom: .75rem;
  }
  .ct-channel-card__avatar {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .ct-channel-card__role {
    font-size: .75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--md-on-surface-variant); margin-bottom: .2rem;
  }
  .ct-channel-card__email {
    font-size: .92rem; font-weight: 700; color: var(--md-primary);
    transition: opacity .2s;
  }
  .ct-channel-card__email:hover { opacity: .75; }

  .ct-channel-card__area-label {
    display: inline-block;
    font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--md-primary);
    background: var(--md-primary-container);
    border: 1px solid rgba(0,82,154,.18);
    border-radius: var(--r-full); padding: .25rem .85rem;
    margin-bottom: 1rem;
  }

  .ct-channel-card__cols {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }
  @media (max-width: 540px) { .ct-channel-card__cols { grid-template-columns: 1fr; } }

  .ct-channel-col__title {
    font-size: .72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .1em; color: var(--md-on-surface-variant);
    margin-bottom: .5rem;
  }
  .ct-channel-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: .3rem;
  }
  .ct-channel-list li {
    font-size: .86rem; color: var(--md-on-surface);
    display: flex; align-items: flex-start; gap: .5rem; line-height: 1.5;
  }
  .ct-channel-list li::before {
    content: '';
    display: inline-block; flex-shrink: 0;
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--md-primary);
    margin-top: .45rem;
  }
</style>

<script>
  /* ── Reveal al scroll ── */
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  /* ── Validación y envío simulado ── */
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('ct-submit') as HTMLButtonElement;
  const success = document.getElementById('ct-success') as HTMLElement;
  const error = document.getElementById('ct-error') as HTMLElement;
  const errorTitle = document.getElementById('error-title') as HTMLElement;
  const errorMessage = document.getElementById('error-message') as HTMLElement;

  function validate(el: HTMLInputElement | HTMLTextAreaElement) {
    const field = el.closest('.ct-field')!;
    let ok = el.checkValidity();
    
    // Validación adicional para email
    if (el.type === 'email' && el.value) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(el.value)) {
        ok = false;
        el.setCustomValidity('Ingrese un correo electrónico válido');
      } else {
        el.setCustomValidity('');
      }
    }
    
    // Validación de longitud para mensaje
    if (el.id === 'f-note' && el.value) {
      if (el.value.length < 10) {
        ok = false;
        el.setCustomValidity('El mensaje debe tener al menos 10 caracteres');
      } else if (el.value.length > 1000) {
        ok = false;
        el.setCustomValidity('El mensaje no puede exceder 1000 caracteres');
      } else {
        el.setCustomValidity('');
      }
    }
    
    field.classList.toggle('has-error', !ok);
    return ok;
  }

  form?.querySelectorAll('.ct-input').forEach(inp => {
    (inp as HTMLElement).addEventListener('blur', e => validate(e.target as HTMLInputElement));
    (inp as HTMLElement).addEventListener('input', e => {
      const field = (e.target as HTMLElement).closest('.ct-field')!;
      if (field.classList.contains('has-error')) validate(e.target as HTMLInputElement);
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Ocultar mensajes anteriores
    success.hidden = true;
    error.hidden = true;
    
    // Validar todos los campos
    let valid = true;
    form.querySelectorAll('.ct-input').forEach(inp => {
      if (!(inp as HTMLInputElement).required) return;
      if (!validate(inp as HTMLInputElement)) valid = false;
    });
    if (!valid) return;

    // Deshabilitar botón y mostrar estado de carga
    const originalBtnHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = `
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="spinner">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.25"/>
        <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
      Enviando…
    `;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name:    (document.getElementById('f-name')    as HTMLInputElement).value.trim(),
          email:   (document.getElementById('f-email')   as HTMLInputElement).value.trim(),
          phone:   (document.getElementById('f-phone')   as HTMLInputElement).value.trim() || '',
          message: (document.getElementById('f-note')    as HTMLTextAreaElement).value.trim(),
        }),
      });

      const data = await res.json();

      if (res.ok && data.success) {
        form.style.display = 'none';
        success.hidden = false;
      } else {
        // Mostrar error específico
        errorTitle.textContent = 'Error al enviar';
        errorMessage.textContent = data.error || 'Por favor intente de nuevo.';
        error.hidden = false;
        
        // Restaurar botón
        btn.disabled = false;
        btn.innerHTML = originalBtnHTML;
      }
    } catch (err) {
      // Mostrar error de red
      errorTitle.textContent = 'Error de conexión';
      errorMessage.textContent = 'Verifique su conexión a internet e intente de nuevo.';
      error.hidden = false;
      
      // Restaurar botón
      btn.disabled = false;
      btn.innerHTML = originalBtnHTML;
    }
  });

  /* ── MODAL: Canales de Atención ── */
  const btnChannels = document.getElementById('btn-channels');
  const btnClose    = document.getElementById('btn-channels-close');
  const modalBackdrop = document.getElementById('channels-modal') as HTMLElement;

  function openModal() {
    modalBackdrop.hidden = false;
    // Force reflow before adding class for transition
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        modalBackdrop.classList.add('is-open');
        btnChannels?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      });
    });
  }

  function closeModal() {
    modalBackdrop.classList.remove('is-open');
    btnChannels?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    setTimeout(() => { modalBackdrop.hidden = true; }, 350);
  }

  btnChannels?.addEventListener('click', openModal);
  btnClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', (e) => {
    if (e.target === modalBackdrop) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modalBackdrop.hidden) closeModal();
  });
</script>
