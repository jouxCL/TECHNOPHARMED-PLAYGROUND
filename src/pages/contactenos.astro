---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contáctenos – Technopharmed" description="Comuníquese con el equipo de Technopharmed. Asesoría técnica y comercial disponible.">

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  HERO EXCLUSIVO DE CONTACTO                           -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="ct-hero" aria-label="Contáctenos">
    <!-- Fondo animado con gradiente pulsante -->
    <div class="ct-hero__bg" aria-hidden="true">
      <div class="ct-bg-orb ct-bg-orb--1"></div>
      <div class="ct-bg-orb ct-bg-orb--2"></div>
      <div class="ct-bg-orb ct-bg-orb--3"></div>
      <div class="ct-grid" aria-hidden="true"></div>
    </div>

    <!-- Contenido hero -->
    <div class="ct-hero__content">
      <span class="ct-eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 013 3.18 2 2 0 015 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L9.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Comuníquese con Nosotros
      </span>

      <h1 class="ct-hero__title">
        Estamos listos para<br/>
        <span class="ct-gradient-text">servirle.</span>
      </h1>

      <p class="ct-hero__subtitle">
        Nuestro equipo de expertos técnicos y comerciales está disponible para brindarle la asesoría que su empresa necesita. Cuéntenos su proyecto.
      </p>

      <!-- Scroll indicator -->
      <div class="ct-scroll-hint" aria-hidden="true">
        <div class="ct-scroll-hint__dot"></div>
      </div>
    </div>

    <!-- Decoraciones geométricas -->
    <div class="ct-hero__deco" aria-hidden="true">
      <div class="ct-deco-ring ct-deco-ring--lg"></div>
      <div class="ct-deco-ring ct-deco-ring--sm"></div>
      <div class="ct-deco-line ct-deco-line--v"></div>
      <div class="ct-deco-line ct-deco-line--h"></div>
    </div>

    <!-- Wave inferior -->
    <div class="ct-hero__wave">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 72" preserveAspectRatio="none" style="width: 100%; height: 72px; display: block;">
        <path fill="var(--md-bg,#F8F9FC)" d="M0,36 C480,72 960,0 1440,36 L1440,72 L0,72 Z"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  FORMULARIO + DIRECTORIO                              -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="ct-main">
    <div class="ct-inner">

      <!-- ── Columna izquierda: Formulario ── -->
      <div class="ct-form-col reveal">
        <p class="pg-eyebrow">Formulario de Contacto</p>
        <h2 class="ct-section-title">Envíenos un Mensaje</h2>
        <p class="ct-section-body">Diligenciemos el formulario y uno de nuestros asesores se comunicará con usted en las próximas 24 horas hábiles.</p>

        <form id="contact-form" class="ct-form" novalidate>
          <!-- Nombre -->
          <div class="ct-field" id="field-name">
            <label class="ct-label" for="f-name">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2"/></svg>
              Nombre completo
            </label>
            <input id="f-name" name="nombre" type="text" class="ct-input" placeholder="Ej. Laura García" autocomplete="name" required />
            <span class="ct-field__error">Por favor ingrese su nombre.</span>
          </div>

          <!-- Correo -->
          <div class="ct-field" id="field-email">
            <label class="ct-label" for="f-email">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="2"/><path d="M2 8l10 7 10-7" stroke="currentColor" stroke-width="2"/></svg>
              Correo electrónico
            </label>
            <input id="f-email" name="correo" type="email" class="ct-input" placeholder="correo@empresa.com" autocomplete="email" required />
            <span class="ct-field__error">Ingrese un correo válido.</span>
          </div>

          <!-- Teléfono -->
          <div class="ct-field" id="field-phone">
            <label class="ct-label" for="f-phone">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="currentColor" stroke-width="2"/></svg>
              Teléfono / Celular
            </label>
            <input id="f-phone" name="telefono" type="tel" class="ct-input" placeholder="+57 300 000 0000" autocomplete="tel" />
          </div>

          <!-- Nota -->
          <div class="ct-field" id="field-note">
            <label class="ct-label" for="f-note">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Nota / Descripción del proyecto
            </label>
            <textarea id="f-note" name="nota" class="ct-input ct-textarea" placeholder="Cuéntenos sobre su proceso, tipo de máquina de interés, capacidad requerida…" rows="5" required></textarea>
            <span class="ct-field__error">Por favor describa su consulta.</span>
          </div>

          <!-- Submit -->
          <div class="ct-form__actions">
            <button type="submit" id="ct-submit" class="ct-btn-submit">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/></svg>
              Enviar Mensaje
            </button>
            <p class="ct-disclaimer">* Al enviar, acepta que nos comuniquemos con usted para brindarle atención técnica y comercial.</p>
          </div>

          <!-- Estado enviado -->
          <div id="ct-success" class="ct-success" hidden>
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#1D6B3A" stroke-width="2"/><path d="M7 12l4 4 6-6" stroke="#1D6B3A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div>
              <p class="ct-success__title">¡Mensaje enviado!</p>
              <p class="ct-success__body">Le responderemos pronto. Gracias por contactarnos.</p>
            </div>
          </div>
        </form>
      </div>

      <!-- ── Columna derecha: Info de contacto ── -->
      <div class="ct-info-col">

        <!-- Directorio -->
        <div class="ct-dir-card reveal stagger-1">
          <p class="pg-eyebrow">Directorio</p>
          <h3 class="ct-section-title" style="font-size:1.4rem;">Nuestro Equipo</h3>

          <div class="ct-person">
            <div class="ct-person__avatar">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <div>
              <p class="ct-person__role">Gerente General</p>
              <p class="ct-person__name">Ing. Juan Quintero</p>
              <a class="ct-person__link" href="mailto:gerencia@technopharmed.com">gerencia@technopharmed.com</a>
              <a class="ct-person__link" href="tel:+573138311426">313 831 1426</a>
            </div>
          </div>
          <div class="ct-divider"></div>
          <div class="ct-person">
            <div class="ct-person__avatar">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <div>
              <p class="ct-person__role">Administrativo</p>
              <p class="ct-person__name">Claudia Santa</p>
              <a class="ct-person__link" href="mailto:administrativo@technopharmed.net">administrativo@technopharmed.net</a>
              <a class="ct-person__link" href="tel:+573136273694">313 627 36 94</a>
            </div>
          </div>
        </div>

        <!-- Sede -->
        <div class="ct-sede-card reveal stagger-2">
          <p class="pg-eyebrow">Ubicación</p>
          <h3 class="ct-section-title" style="font-size:1.4rem;">Nuestra Sede</h3>
          
          <div class="ct-sede-rows">
            <div class="ct-sede-row">
              <div class="ct-sede-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="2"/></svg>
              </div>
              <span>Carrera 3F Nº 32A - 13,<br/>Manizales, Caldas – Colombia</span>
            </div>
            <div class="ct-sede-row">
              <div class="ct-sede-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="currentColor" stroke-width="2"/></svg>
              </div>
              <a href="tel:+573138311426">(+57) 313 831 1426</a>
            </div>
            <div class="ct-sede-row">
              <div class="ct-sede-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke="currentColor" stroke-width="2"/></svg>
              </div>
              <a href="https://www.technopharmed.com" target="_blank" rel="noopener">www.technopharmed.com</a>
            </div>
          </div>

          <!-- Mapa -->
          <div class="ct-map">
            <iframe
              title="Ubicación Technopharmed – Manizales"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3975.2843!2d-75.5197!3d5.0686!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e4767bec72deab5%3A0x1!2sCarrera+3F+%2332A-13%2C+Manizales%2C+Caldas!5e0!3m2!1ses!2sco!4v1700000000000"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>

      </div><!-- /ct-info-col -->
    </div><!-- /ct-inner -->
  </section>

</Layout>

<style is:global>
  /* ══════════════════════════════════
     HERO
  ══════════════════════════════════ */
  .ct-hero {
    position: relative;
    min-height: 55vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #001D36;
  }

  /* Fondo con orbs */
  .ct-hero__bg { position: absolute; inset: 0; z-index: 0; }

  .ct-bg-orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); pointer-events: none;
    animation: orbPulse 8s ease-in-out infinite;
  }
  .ct-bg-orb--1 { width:500px; height:500px; background:rgba(0,82,154,.45); top:-200px; left:-100px; }
  .ct-bg-orb--2 { width:380px; height:380px; background:rgba(0,53,112,.35); bottom:-120px; right:-80px; animation-delay:2.5s; }
  .ct-bg-orb--3 { width:220px; height:220px; background:rgba(158,202,255,.08); top:30%; left:40%; animation-delay:5s; }

  @keyframes orbPulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.12);opacity:.75} }

  /* Grilla de puntos */
  .ct-grid {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(158,202,255,.14) 1.5px, transparent 1.5px);
    background-size: 30px 30px;
    opacity: .4;
  }

  /* Decoraciones geométricas */
  .ct-hero__deco { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .ct-deco-ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(158,202,255,.1);
  }
  .ct-deco-ring--lg { width:600px; height:600px; top:-250px; right:-200px; animation: slowSpin 90s linear infinite; }
  .ct-deco-ring--sm { width:220px; height:220px; bottom:-80px; left:12%; animation: slowSpin 50s linear infinite reverse; }
  .ct-deco-line {
    position: absolute;
    background: linear-gradient(transparent, rgba(158,202,255,.18), transparent);
  }
  .ct-deco-line--v { width:1px; height:200px; right:14%; top:10%; animation: lineFade 4s ease-in-out infinite; }
  .ct-deco-line--h { height:1px; width:160px; left:8%; bottom:28%; animation: lineFade 4s ease-in-out infinite 1.8s; background: linear-gradient(to right, transparent, rgba(158,202,255,.18), transparent); }

  @keyframes slowSpin { to{ transform:rotate(360deg); } }
  @keyframes lineFade { 0%,100%{opacity:.2} 50%{opacity:1} }

  /* Contenido */
  .ct-hero__content {
    position: relative; z-index: 2;
    width: 100%; max-width: 720px;
    margin: 0 auto;
    padding: 6rem 2rem 5rem;
    text-align: center;
  }

  .ct-eyebrow {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(158,202,255,.1); border: 1px solid rgba(158,202,255,.25);
    padding: .35rem 1.1rem; border-radius: 9999px;
    color: #9ECAFF; font-size: .72rem; font-weight: 600; letter-spacing: .12em;
    text-transform: uppercase; margin-bottom: 1.5rem;
    backdrop-filter: blur(8px);
    animation: ctFadeUp .6s both .1s;
  }

  .ct-hero__title {
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    font-weight: 900; color: #fff; line-height: 1.05;
    letter-spacing: -.02em; margin-bottom: 1.25rem;
    animation: ctFadeUp .6s both .25s;
  }
  .ct-gradient-text {
    background: linear-gradient(95deg, #9ECAFF 0%, #60B0FF 50%, #B3D6FF 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ct-hero__subtitle {
    font-size: 1.1rem; color: rgba(255,255,255,.72);
    line-height: 1.75; max-width: 560px; margin: 0 auto 2rem;
    animation: ctFadeUp .6s both .4s;
  }

  /* Scroll indicator */
  .ct-scroll-hint {
    display: flex; justify-content: center;
    animation: ctFadeUp .6s both .6s;
  }
  .ct-scroll-hint__dot {
    width: 28px; height: 44px; border: 2px solid rgba(158,202,255,.35);
    border-radius: 9999px; position: relative;
  }
  .ct-scroll-hint__dot::after {
    content:''; position:absolute; left:50%; top:6px;
    transform: translateX(-50%);
    width:5px; height:5px; border-radius:50%;
    background: #9ECAFF;
    animation: scrollDot 2s ease-in-out infinite;
  }
  @keyframes scrollDot { 0%{opacity:1;transform:translateX(-50%) translateY(0)} 80%{opacity:0;transform:translateX(-50%) translateY(16px)} 100%{opacity:0;transform:translateX(-50%) translateY(0)} }

  /* Wave */
  .ct-hero__wave {
    position: absolute; bottom: 0; left: 0; right: 0; z-index: 2; line-height: 0;
  }

  @keyframes ctFadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }

  /* ══════════════════════════════════
     MAIN (formulario + info)
  ══════════════════════════════════ */
  .ct-main { padding: 5rem 2rem 6rem; }
  .ct-inner {
    max-width: 1140px; margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) { .ct-inner { grid-template-columns: 1fr; } }

  /* Eyebrow reutilizado de M3 */
  .pg-eyebrow {
    font-size: .72rem; font-weight: 700; letter-spacing: .14em;
    text-transform: uppercase; color: var(--md-primary);
    display: flex; align-items: center; gap: .45rem; margin-bottom: .6rem;
  }
  .pg-eyebrow::before { content:''; width:24px; height:2px; background:var(--md-primary); border-radius:2px; }

  .ct-section-title {
    font-size: 1.85rem; font-weight: 800; color: var(--md-on-surface);
    line-height: 1.15; margin-bottom: .75rem;
  }
  .ct-section-body {
    font-size: .98rem; color: var(--md-on-surface-variant);
    line-height: 1.75; margin-bottom: 2rem; max-width: 500px;
  }

  /* ── FORMULARIO ── */
  .ct-form { display: flex; flex-direction: column; gap: 1.4rem; }

  .ct-field { display: flex; flex-direction: column; gap: .42rem; }

  .ct-label {
    display: flex; align-items: center; gap: .4rem;
    font-size: .82rem; font-weight: 600;
    color: var(--md-on-surface-variant);
    transition: color .2s;
  }
  .ct-label svg { flex-shrink: 0; }

  .ct-input {
    width: 100%;
    background: var(--md-surface);
    border: 1.5px solid var(--md-outline-variant);
    border-radius: var(--r-md, 12px);
    padding: .9rem 1.1rem;
    font-size: .97rem; color: var(--md-on-surface);
    font-family: inherit;
    transition: border-color .2s, box-shadow .2s, background .2s;
    outline: none;
    resize: none;
  }
  .ct-input::placeholder { color: var(--md-outline); }
  .ct-input:focus {
    border-color: var(--md-primary);
    box-shadow: 0 0 0 3px rgba(0,82,154,.15);
    background: var(--md-surface-container-low, #fff);
  }
  .ct-input.error { border-color: #B91C1C; box-shadow: none; }

  .ct-field__error {
    font-size: .78rem; color: #B91C1C;
    display: none; padding-left: .2rem;
  }
  .ct-field.has-error .ct-field__error { display: block; }
  .ct-field.has-error .ct-label { color: #B91C1C; }
  .ct-field.has-error .ct-input { border-color: #B91C1C; }

  .ct-textarea { min-height: 130px; line-height: 1.6; }

  .ct-form__actions { display: flex; flex-direction: column; gap: .75rem; margin-top: .5rem; }

  .ct-btn-submit {
    display: inline-flex; align-items: center; justify-content: center; gap: .6rem;
    background: var(--md-primary);
    color: var(--md-on-primary, #fff);
    border: none; border-radius: var(--r-full, 9999px);
    padding: 1rem 2.2rem;
    font-size: 1rem; font-weight: 700; font-family: inherit;
    cursor: pointer;
    transition: background .2s, transform .15s, box-shadow .2s;
    box-shadow: var(--el-2, 0 2px 8px rgba(0,0,0,.12));
    align-self: flex-start;
  }
  .ct-btn-submit:hover { background: #003B7A; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,82,154,.3); }
  .ct-btn-submit:active { transform: translateY(0); }
  .ct-btn-submit:disabled { opacity: .55; cursor: not-allowed; transform: none; }

  .ct-disclaimer { font-size: .76rem; color: var(--md-outline); line-height: 1.5; }

  /* Estado success */
  .ct-success {
    display: flex; align-items: center; gap: 1rem;
    background: #ECFDF5; border: 1.5px solid #6EE7B7;
    border-radius: var(--r-lg, 16px); padding: 1.25rem 1.5rem;
    animation: ctFadeUp .4s both;
  }
  .ct-success[hidden] { display: none; }
  .ct-success__title { font-size: 1rem; font-weight: 700; color: #1D6B3A; }
  .ct-success__body  { font-size: .88rem; color: #2C7A4B; margin-top: .2rem; }

  /* ── DIRECTORIO ── */
  .ct-dir-card, .ct-sede-card {
    background: var(--md-surface);
    border: 1px solid var(--md-outline-variant);
    border-radius: var(--r-xl, 20px);
    padding: 2rem;
    box-shadow: var(--el-1, 0 1px 4px rgba(0,0,0,.06));
  }
  .ct-info-col { display: flex; flex-direction: column; gap: 1.5rem; }

  .ct-person { display: flex; align-items: flex-start; gap: 1rem; padding: .75rem 0; }
  .ct-person__avatar {
    flex-shrink: 0; width: 42px; height: 42px; border-radius: 50%;
    background: var(--md-primary-container); color: var(--md-on-primary-container);
    display: flex; align-items: center; justify-content: center;
  }
  .ct-person__role  { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--md-primary); margin-bottom: .15rem; }
  .ct-person__name  { font-size: 1rem; font-weight: 700; color: var(--md-on-surface); margin-bottom: .35rem; }
  .ct-person__link  { display: block; font-size: .86rem; color: var(--md-primary); transition: opacity .2s; }
  .ct-person__link:hover { opacity: .75; }
  .ct-divider { height: 1px; background: var(--md-outline-variant); margin: .1rem 0; }

  /* ── SEDE ── */
  .ct-sede-rows { display: flex; flex-direction: column; gap: .85rem; margin-bottom: 1.5rem; }
  .ct-sede-row {
    display: flex; align-items: flex-start; gap: .85rem;
    font-size: .92rem; color: var(--md-on-surface-variant); line-height: 1.55;
  }
  .ct-sede-row a { color: var(--md-primary); transition: opacity .2s; }
  .ct-sede-row a:hover { opacity: .75; }
  .ct-sede-icon {
    flex-shrink: 0; width: 34px; height: 34px; border-radius: 50%;
    background: var(--md-surface-container);
    border: 1px solid var(--md-outline-variant);
    display: flex; align-items: center; justify-content: center;
    color: var(--md-primary);
  }
  .ct-map {
    width: 100%; aspect-ratio: 16/9;
    border-radius: var(--r-lg, 16px); overflow: hidden;
    border: 1px solid var(--md-outline-variant);
  }
  .ct-map iframe { width:100%; height:100%; border:0; display:block; }
</style>

<script>
  /* ── Reveal al scroll ── */
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  /* ── Validación y envío simulado ── */
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('ct-submit') as HTMLButtonElement;
  const success = document.getElementById('ct-success') as HTMLElement;

  function validate(el: HTMLInputElement | HTMLTextAreaElement) {
    const field = el.closest('.ct-field')!;
    const ok = el.checkValidity();
    field.classList.toggle('has-error', !ok);
    return ok;
  }

  form?.querySelectorAll('.ct-input').forEach(inp => {
    (inp as HTMLElement).addEventListener('blur', e => validate(e.target as HTMLInputElement));
    (inp as HTMLElement).addEventListener('input', e => {
      const field = (e.target as HTMLElement).closest('.ct-field')!;
      if (field.classList.contains('has-error')) validate(e.target as HTMLInputElement);
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    let valid = true;
    form.querySelectorAll('.ct-input').forEach(inp => {
      if (!(inp as HTMLInputElement).required) return;
      if (!validate(inp as HTMLInputElement)) valid = false;
    });
    if (!valid) return;

    btn.disabled = true;
    btn.textContent = 'Enviando…';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name:    (document.getElementById('f-name')    as HTMLInputElement).value,
          email:   (document.getElementById('f-email')   as HTMLInputElement).value,
          phone:   (document.getElementById('f-phone')   as HTMLInputElement).value,
          message: (document.getElementById('f-note')    as HTMLTextAreaElement).value,
        }),
      });

      const data = await res.json();

      if (res.ok && data.success) {
        form.style.display = 'none';
        success.hidden = false;
      } else {
        alert('Error al enviar el mensaje: ' + (data.error || 'Intente de nuevo.'));
        btn.disabled = false;
        btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/></svg> Enviar Mensaje`;
      }
    } catch (err) {
      alert('Error de red. Por favor verifique su conexión e intente de nuevo.');
      btn.disabled = false;
      btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/></svg> Enviar Mensaje`;
    }
  });
</script>
