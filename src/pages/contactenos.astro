    margin-left: auto;
    transition: transform .3s var(--ease-standard, cubic-bezier(.2,0,0,1));
  }
  .ct-channels-btn[aria-expanded="true"] .ct-channels-btn__chevron { transform: rotate(180deg); }

  /* ── MODAL BACKDROP ── */
  .ct-modal-backdrop {
