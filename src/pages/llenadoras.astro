    --md-filled-button-container-color: #fff;
    --md-filled-button-hover-container-color: #F0F4F8;
    --md-filled-button-label-text-color: var(--md-primary);
    --md-filled-button-hover-label-text-color: var(--md-primary);
    --md-filled-button-container-shape: 9999px;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.flip-card').forEach(card => {
    const toggle = () => {
      const isFlipped = card.classList.toggle('is-flipped');
      card.setAttribute('aria-pressed', String(isFlipped));
    };
    card.addEventListener('click', toggle);
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
    });
  });
</script>