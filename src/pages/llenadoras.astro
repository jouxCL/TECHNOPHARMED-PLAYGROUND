---
import Layout from '../layouts/Layout.astro';
import HeroPage from '../components/HeroPage.astro';
---

<Layout title="Llenadoras de Líquidos – Technopharmed" description="FILAMATIC – automatización de llenado de líquidos para la industria farmacéutica. Llenadoras semiautomáticas Heavy Duty, sistemas inline y Monobloc.">

  <!-- Animated background orbs -->
  <div class="page-orbs" aria-hidden="true">
    <div class="page-orb page-orb--1"></div>
    <div class="page-orb page-orb--2"></div>
    <div class="page-orb page-orb--3"></div>
  </div>

  <HeroPage
    eyebrow="Línea de Llenadoras · Filamatic"
    title="Innovación y Automatización en <em>Llenado de Líquidos.</em>"
    subtitle="A través de nuestra alianza con Filamatic, marca global líder, le proporcionamos ingeniería extraordinaria y soluciones de llenado que garantizan una dosificación controlada y de máxima calidad para satisfacer los más altos estándares de la industria."
    ctaLabel="Solicitar Asesoría Técnica"
    ctaHref="/contactenos"
    videoSrc="/videos/LlenadorasDeLiquido.mp4"
  />




  <!-- Logos bar -->
  <div class="llen-logos-bar reveal">
    <span class="llen-logos-bar__label">Una alianza entre</span>
    <img src="/logos/logo1.svg" alt="Technopharmed" class="llen-logo llen-logo--tech" />
    <span class="llen-logos-bar__sep" aria-hidden="true">×</span>
    <img
      src="/images/llenadoras de liquido/FilamaticaMiniLogo.png"
      alt="Filamatic"
      class="llen-logo llen-logo--filamatic"
      width="291"
      height="71"
    />
  </div>


  <!-- ═══════════════════════════════════════════════════

       SECCIÓN 1: SERIE HEAVY DUTY — FLIP CARDS 2×2
       ═══════════════════════════════════════════════════ -->
  <section class="pg-section" aria-labelledby="s1-title">
    <div class="pg-inner">
      <p class="eyebrow-shimmer reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21.02 7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/></svg>
        Llenadoras Semiautomáticas · Heavy Duty Series
      </p>
      <div class="llen-section-intro reveal stagger-1">
        <h2 id="s1-title" class="pg-title">Versatilidad y Precisión<br /><em class="text-primary">Multiboquilla.</em></h2>
        <p class="pg-body">
          Equipos de sobremesa versátiles y de alto rendimiento. Diseñadas con control de velocidad variable, son ideales para dispensar desde fluidos acuosos hasta productos altamente viscosos con un proceso de cambio increíblemente rápido.
        </p>
        <p class="llen-hint reveal stagger-2">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 15l-2 5L9 9l11 4-5 2z"/></svg>
          Haz clic en una tarjeta para ver sus especificaciones técnicas
        </p>
      </div>

      <div class="llen-grid reveal stagger-3">

        <!-- TARJETA 1: DAB-8-2 -->
        <div class="flip-card" role="button" tabindex="0" aria-label="DAB-8-2 — Ver detalles técnicos" aria-pressed="false">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <div class="flip-card__img-wrap">
                <img src="/images/llenadoras de liquido/DAB-8-2.png" alt="Máquina Llenadora DAB-8-2" class="flip-card__img" />
              </div>
              <div class="flip-card__body">
                <p class="flip-card__model">DAB-8-2</p>
                <p class="flip-card__name">Doble Boquilla · Alta Velocidad</p>
                <span class="flip-card__cue">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                  Ver especificaciones
                </span>
              </div>
            </div>
            <!-- REVERSO DAB-8-2 -->
            <div class="flip-card__back">
              <div class="flip-card__back-header">
                <span class="flip-card__back-model">DAB-8-2</span>
                <span class="flip-card__close-cue">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                  Volver
                </span>
              </div>
              <h3 class="flip-card__back-title">Detalles Técnicos DAB-8-2</h3>
              <p class="flip-card__back-desc">
                Semiautomática de sobremesa para alta precisión y velocidad. Su sistema de doble boquilla duplica la tasa de producción, ideal para líquidos acuosos hasta aceites esenciales.
              </p>
              <ul class="flip-card__features">
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Precisión y Volumen:</strong> Rango de 1 ml a 260 ml. Precisión volumétrica de ±0.5%.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Velocidad Operativa:</strong> Hasta 174 ciclos por minuto.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Calidad Farmacéutica:</strong> Estructura de acero inoxidable 316.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Escalabilidad:</strong> Diseño modular, integrable en sistemas automáticos.</span>
                </li>
              </ul>
              <div class="flip-card__back-chips">
                <span class="m3-chip">2 Boquillas</span>
                <span class="m3-chip">Alta Velocidad</span>
                <span class="m3-chip">1 ml – 260 ml</span>
              </div>
            </div>
          </div>
        </div>

        <!-- TARJETA 2: DAB-8-4 -->
        <div class="flip-card" role="button" tabindex="0" aria-label="DAB-8-4 — Ver detalles técnicos" aria-pressed="false">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <div class="flip-card__img-wrap">
                <img src="/images/llenadoras de liquido/DAB-8-4.png" alt="Máquina Llenadora DAB-8-4" class="flip-card__img" />
              </div>
              <div class="flip-card__body">
                <p class="flip-card__model">DAB-8-4</p>
                <p class="flip-card__name">Cuatro Boquillas · Máx. Versatilidad</p>
                <span class="flip-card__cue">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                  Ver especificaciones
                </span>
              </div>
            </div>
            <!-- REVERSO DAB-8-4 -->
            <div class="flip-card__back">
              <div class="flip-card__back-header">
                <span class="flip-card__back-model">DAB-8-4</span>
                <span class="flip-card__close-cue">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                  Volver
                </span>
              </div>
              <h3 class="flip-card__back-title">Detalles Técnicos DAB-8-4</h3>
              <p class="flip-card__back-desc">
                Configuración de máxima productividad dentro de la gama de 260 ml. Solución definitiva para líneas que demandan versatilidad con alto rendimiento en formato compacto.
              </p>
              <ul class="flip-card__features">
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Versatilidad Extrema:</strong> Dosificación simultánea de dos líquidos diferentes.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Adaptabilidad:</strong> Fluidos, semiviscosos y partículas en suspensión.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Opciones Avanzadas:</strong> Boquillas de buceo para evitar formación de espuma.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Seguridad:</strong> Certificación CE o a prueba de explosión disponible.</span>
                </li>
              </ul>
              <div class="flip-card__back-chips">
                <span class="m3-chip">4 Boquillas</span>
                <span class="m3-chip">Máx. Versatilidad</span>
                <span class="m3-chip">1 ml – 260 ml</span>
              </div>
            </div>
          </div>
        </div>

        <!-- TARJETA 3: DAB-32-2 -->
        <div class="flip-card" role="button" tabindex="0" aria-label="DAB-32-2 — Ver detalles técnicos" aria-pressed="false">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <div class="flip-card__img-wrap">
                <img src="/images/llenadoras de liquido/DAB-32-2.png" alt="Máquina Llenadora DAB-32-2" class="flip-card__img" />
              </div>
              <div class="flip-card__body">
                <p class="flip-card__model">DAB-32-2</p>
                <p class="flip-card__name">2 Boquillas · Alta Viscosidad</p>
                <span class="flip-card__cue">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                  Ver especificaciones
                </span>
              </div>
            </div>
            <!-- REVERSO DAB-32-2 -->
            <div class="flip-card__back">
              <div class="flip-card__back-header">
                <span class="flip-card__back-model">DAB-32-2</span>
                <span class="flip-card__close-cue">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                  Volver
                </span>
              </div>
              <h3 class="flip-card__back-title">Detalles Técnicos DAB-32-2</h3>
              <p class="flip-card__back-desc">
                El "caballo de batalla" para servicio pesado con productos de alta viscosidad. Desplaza cremas densas, geles y fundidos con uniformidad excepcional.
              </p>
              <ul class="flip-card__features">
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Potencia Superior:</strong> Motor de 1 HP con más de 3,000 in/lbs de torque.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Gran Capacidad:</strong> Precisión ±0.5% en volúmenes de hasta 1,100 ml/boquilla.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Durabilidad:</strong> Acero inoxidable 316 para mantenimiento exigente.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Expandible:</strong> Sistema ampliable de 2 a 4 boquillas en el futuro.</span>
                </li>
              </ul>
              <div class="flip-card__back-chips">
                <span class="m3-chip">2 Boquillas</span>
                <span class="m3-chip">Alto Torque</span>
                <span class="m3-chip">Hasta 1,100 ml</span>
              </div>
            </div>
          </div>
        </div>

        <!-- TARJETA 4: DAB-32-4 -->
        <div class="flip-card" role="button" tabindex="0" aria-label="DAB-32-4 — Ver detalles técnicos" aria-pressed="false">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <div class="flip-card__img-wrap">
                <img src="/images/llenadoras de liquido/DAB-32-4.png" alt="Máquina Llenadora DAB-32-4" class="flip-card__img" />
              </div>
              <div class="flip-card__body">
                <p class="flip-card__model">DAB-32-4</p>
                <p class="flip-card__name">4 Boquillas · Máxima Capacidad</p>
                <span class="flip-card__cue">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                  Ver especificaciones
                </span>
              </div>
            </div>
            <!-- REVERSO DAB-32-4 -->
            <div class="flip-card__back">
              <div class="flip-card__back-header">
                <span class="flip-card__back-model">DAB-32-4</span>
                <span class="flip-card__close-cue">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                  Volver
                </span>
              </div>
              <h3 class="flip-card__back-title">Detalles Técnicos DAB-32-4</h3>
              <p class="flip-card__back-desc">
                El sistema semiautomático más potente de la serie Heavy Duty. Combina un motor industrial con precisión de dosificación de nivel farmacéutico para procesos exigentes.
              </p>
              <ul class="flip-card__features">
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Máximo Rendimiento:</strong> Cuatro boquillas de llenado constante hasta 1,100 ml.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Resistencia Mecánica:</strong> Maneja productos de alta resistencia y partículas sólidas.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Flexibilidad:</strong> Adaptable a vidrio, plástico, bolsas flexibles y jeringas.</span>
                </li>
                <li>
                  <span class="feature-dot"></span>
                  <span><strong>Entornos Clasificados:</strong> Opción de operación 100% neumática.</span>
                </li>
              </ul>
              <div class="flip-card__back-chips">
                <span class="m3-chip">4 Boquillas</span>
                <span class="m3-chip">Máxima Capacidad</span>
                <span class="m3-chip">Hasta 1,100 ml</span>
              </div>
            </div>
          </div>
        </div>

      </div><!-- /llen-grid -->
    </div>
  </section>




  <!-- ═══════════════════════════════════════════════════
       SECCIÓN 5: CTA / RESPALDO TÉCNICO
       ═══════════════════════════════════════════════════ -->
  <section class="pg-section pg-section--blue" id="contacto">
    <div class="pg-inner">
      <div class="blue-cta reveal">
        <p class="eyebrow-shimmer" style="background:rgba(158,202,255,.12);border-color:rgba(158,202,255,.28);color:#9ECAFF;animation:none;">
          Respaldo Técnico · Technopharmed
        </p>
        <h2 class="blue-cta__title">Escale su Producción con Respaldo Experto.</h2>
        <p class="blue-cta__body">
          Desde equipos semiautomáticos hasta líneas integradas completas, nuestro equipo de ingenieros evalúa sus necesidades específicas de viscosidad y producción para garantizar la selección del equipo ideal.
        </p>
        <div class="chip-row" style="justify-content:center; margin-bottom:2rem;">
          <span class="m3-chip" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);color:#fff;">Evaluación de viscosidad</span>
          <span class="m3-chip" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);color:#fff;">Selección de boquillas</span>
          <span class="m3-chip" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);color:#fff;">Líneas integradas</span>
          <span class="m3-chip" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);color:#fff;">Asesoría comercial</span>
        </div>
        <md-filled-button href="/contactenos">Solicitar Visita Técnica o Comercial</md-filled-button>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* ──────────────────────────────────────────────────
     PAGE LAYOUT UTILITIES
  ────────────────────────────────────────────────── */
  .pg-section          { padding: 5rem 2rem; position: relative; z-index: 1; }
  .pg-section--alt     { background: var(--md-surface-container); }
  .pg-section--blue    { background: linear-gradient(135deg, #001D36 0%, #003570 55%, #00529A 100%); }
  .pg-inner            { max-width: 1100px; margin: 0 auto; }
  .pg-title            { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; color: var(--md-on-surface); line-height: 1.2; margin-bottom: 1rem; }
  .pg-body             { font-size: 1rem; color: var(--md-on-surface-variant); line-height: 1.78; margin-bottom: .75rem; max-width: 680px; }
  .text-primary        { color: var(--md-primary); font-style: normal; }



  /* Chip row */
  .chip-row { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .5rem; }

  /* ──────────────────────────────────────────────────
     LOGOS BAR
  ────────────────────────────────────────────────── */
  .llen-logos-bar {
    display: flex; align-items: center; justify-content: center;
    gap: 1.5rem; padding: 1.25rem 2rem;
    background: var(--md-surface); border-bottom: 1px solid var(--md-outline-variant);
    flex-wrap: wrap;
  }
  .llen-logos-bar__label { font-size: .72rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--md-on-surface-variant); }
  .llen-logo--tech       { height: 36px; width: auto; object-fit: contain; filter: drop-shadow(0 1px 3px rgba(0,0,0,.1)); }
  .llen-logo--filamatic  { height: 36px; width: auto; object-fit: contain; filter: drop-shadow(0 1px 3px rgba(0,0,0,.1)); }
  .llen-logos-bar__sep   { font-size: 1.4rem; font-weight: 300; color: var(--md-outline); line-height: 1; }



  /* ──────────────────────────────────────────────────
     SECTION INTRO & HINT
  ────────────────────────────────────────────────── */
  .llen-section-intro { max-width: 720px; margin-bottom: 1rem; }
  .llen-hint {
    display: inline-flex; align-items: center; gap: .45rem;
    font-size: .82rem; color: var(--md-on-surface-variant);
    background: var(--md-surface-container);
    border: 1px dashed var(--md-outline-variant);
    padding: .4rem .9rem; border-radius: var(--r-full); margin-top: .5rem;
  }
  .llen-hint svg { color: var(--md-primary); flex-shrink: 0; }



  /* ──────────────────────────────────────────────────
     FLIP CARD GRID
  ────────────────────────────────────────────────── */
  .llen-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  @media (max-width: 640px) { .llen-grid { grid-template-columns: 1fr; } }

  /* Container */
  .flip-card {
    perspective: 1200px;
    height: 560px;
    cursor: pointer;
    outline: none;
  }
  .flip-card:focus-visible .flip-card__inner {
    box-shadow: 0 0 0 3px var(--md-primary), var(--el-3);
  }
  .flip-card__inner {
    position: relative; width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform 600ms var(--ease-emphasized), box-shadow 300ms;
    border-radius: var(--r-xl);
  }
  .flip-card.is-flipped .flip-card__inner { transform: rotateY(180deg); }
  .flip-card:not(.is-flipped):hover .flip-card__inner {
    transform: translateY(-5px) scale(1.012);
    box-shadow: var(--el-3), 0 0 0 1px rgba(0,82,154,.18);
  }

  /* Shared face */
  .flip-card__front, .flip-card__back {
    position: absolute; inset: 0;
    border-radius: var(--r-xl);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    overflow: hidden;
  }

  /* ── FRONT ── */
  .flip-card__front {
    background: var(--md-surface);
    border: 1px solid var(--md-outline-variant);
    box-shadow: var(--el-1);
    display: flex; flex-direction: column;
  }
  .flip-card__img-wrap { flex: 1; display: flex; align-items: stretch; justify-content: center; overflow: hidden; }
  .flip-card__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
    transition: transform 300ms ease;
    filter: drop-shadow(0 8px 16px rgba(0,0,0,0.08));
  }
  .flip-card:not(.is-flipped):hover .flip-card__img { transform: scale(1.04); }
  .flip-card__body {
    padding: 1.5rem 1.75rem 1.75rem;
    border-top: 1px solid var(--md-outline-variant);
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .flip-card__model {
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--md-on-surface);
    letter-spacing: -.01em;
    line-height: 1.1;
    margin: 0;
  }
  .flip-card__name {
    font-size: 1rem;
    color: var(--md-on-surface-variant);
    font-weight: 500;
    margin: 0;
  }
  .flip-card__cue {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    margin-top: 1rem;
    font-size: .85rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--md-primary);
    background: var(--md-primary-container);
    padding: 0.6rem 1.2rem;
    border-radius: var(--r-full);
    width: fit-content;
    transition: background 200ms, transform 200ms;
  }
  .flip-card:not(.is-flipped):hover .flip-card__cue { 
    background: var(--md-primary);
    color: var(--md-on-primary);
    transform: scale(1.05);
  }

  /* ── BACK ── */
  .flip-card__back {
    background: linear-gradient(150deg, #001D36 0%, #003570 55%, #00529A 100%);
    transform: rotateY(180deg);
    display: flex;
    flex-direction: column;
    padding: 2rem 2.2rem;
    gap: 1rem;
    color: #fff;
  }
  .flip-card__back-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .flip-card__back-model {
    font-size: .75rem;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #9ECAFF;
    background: rgba(158,202,255,.12);
    border: 1px solid rgba(158,202,255,.25);
    padding: .35rem 1rem;
    border-radius: var(--r-full);
  }
  .flip-card__close-cue {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(255,255,255,.6);
    transition: color 200ms, transform 200ms;
  }
  .flip-card.is-flipped:hover .flip-card__close-cue { color: #fff; transform: scale(1.05); }
  .flip-card__back-title {
    font-size: 1.4rem;
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
    margin: 0;
  }
  .flip-card__back-desc {
    font-size: 1rem;
    color: rgba(255,255,255,.85);
    line-height: 1.65;
    margin: 0;
  }

  /* Feature list */
  .flip-card__features {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: .38rem;
    flex: 1;
  }
  .flip-card__features li {
    display: flex;
    gap: .75rem;
    align-items: flex-start;
    font-size: .95rem;
    color: rgba(255,255,255,.85);
    line-height: 1.6;
  }
  .flip-card__features li strong { color: #9ECAFF; }
  .feature-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--md-primary);
    flex-shrink: 0;
    margin-top: .55rem;
    box-shadow: 0 0 8px rgba(158,202,255,.8);
  }

  /* Back chips */
  .flip-card__back-chips { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: auto; }
  .flip-card__back-chips .m3-chip {
    background: rgba(255,255,255,.1);
    border-color: rgba(255,255,255,.2);
    color: #fff;
    font-size: .8rem;
    padding: 0.4rem 1rem;
  }
  .flip-card__back-chips .m3-chip:hover {
    background: rgba(255,255,255,.18); border-color: rgba(255,255,255,.35); color: #fff; transform: none;
  }

  /* ──────────────────────────────────────────────────
     CTA BLUE SECTION
  ────────────────────────────────────────────────── */
  .blue-cta { text-align: center; }
  .blue-cta__title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 900; color: #fff; line-height: 1.15; margin-bottom: 1rem; }
  .blue-cta__body  { font-size: 1.05rem; color: rgba(255,255,255,.78); line-height: 1.75; max-width: 600px; margin: 0 auto 1.75rem; }
