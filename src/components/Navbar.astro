---
// src/components/Navbar.astro
const pathname = Astro.url.pathname;

const links = [
  { href: '/',                label: 'Inicio'                },
  { href: '/punzoneria',      label: 'Punzonería'            },
  { href: '/llenadoras',      label: 'Llenadoras de Líquidos'},
  { href: '/tableteadoras',   label: 'Tableteadoras'         },
  { href: '/respaldo-tecnico',label: 'Respaldo Técnico'      },
  { href: '/contactenos',     label: 'Contáctenos'           },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<style>
  .navbar {
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 72px;
  }

  /* ─── LOGO ─── */
  .navbar__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .navbar__logo img {
    height: 54px; /* Aumentado para mejor visualización de logo1.svg */
    max-height: 100%;
    width: auto;
    object-fit: contain;
    display: block;
  }

  /* ─── NAV LINKS ─── */
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__nav a {
    display: block;
    padding: 0 1.1rem;
    height: 72px;
    line-height: 72px;
    font-family: 'Roboto', sans-serif;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: #333;
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .navbar__nav a:hover {
    color: #0054a6;
    border-bottom-color: #0054a6;
  }

  /* ─── LINK ACTIVO ─── */
  .navbar__nav a.is-active {
    color: #0054a6;
    border-bottom-color: #0054a6;
    font-weight: 900;
  }

  /* ─── ÚLTIMO LINK (Contáctenos): siempre destaca ─── */
  .navbar__nav a.nav--highlight {
    color: #0054a6;
  }
  .navbar__nav a.nav--highlight:hover,
  .navbar__nav a.nav--highlight.is-active {
    color: #003d80;
    border-bottom-color: #003d80;
  }

  /* ─── MOBILE TOGGLE ─── */
  .navbar__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: #333;
  }

  @media (max-width: 900px) {
    .navbar__toggle { display: flex; align-items: center; }
    
    .navbar__nav {
      position: absolute;
      top: 73px;
      left: 0;
      width: 100%;
      background: #fff;
      flex-direction: column;
      border-bottom: 1px solid #e5e5e5;
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
      display: none; /* Hidden by default */
    }

    .navbar__nav.is-open {
      display: flex !important;
    }

    .navbar__nav a {
      height: 60px;
      line-height: 60px;
      padding: 0 2rem;
      border-bottom: 1px solid #f5f5f5;
    }
    
    .navbar__nav a:last-child {
      border-bottom: none;
    }
  }
</style>

<header class="navbar">
  <div class="navbar__inner">

    <!-- Logo -->
    <div class="navbar__logo">
      <a href="/">
        <img
          src="/logos/logo1.svg"
          alt="Technopharmed"
        />
      </a>
    </div>

    <!-- Navigation -->
    <nav>
      <ul class="navbar__nav" id="mobile-menu">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                { 'is-active': isActive(href) },
                { 'nav--highlight': href === '/contactenos' },
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile button -->
    <button class="navbar__toggle" id="mobile-toggle" type="button" aria-label="Menú" aria-expanded="false" aria-controls="mobile-menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

  </div>
</header>

<script>
  // Simple script to toggle the mobile navigation
  const toggleBtn = document.getElementById('mobile-toggle');
  const navMenu = document.getElementById('mobile-menu');

  if (toggleBtn && navMenu) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', String(!isExpanded));
      navMenu.classList.toggle('is-open');
    });
  }
</script>
