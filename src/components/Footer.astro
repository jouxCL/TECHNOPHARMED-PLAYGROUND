---
// src/components/Footer.astro
---
<style>
/* ════════════════════════════════════
         FOOTER
         ════════════════════════════════════ */
      footer {
        background: var(--md-inverse-surface);
        color: var(--md-inverse-on-surface);
        padding: 4.5rem 2rem 2rem;
        position:relative; overflow:hidden;
      }
      footer::before {
        content:'';
        position:absolute; width:500px; height:500px; border-radius:50%;
        border: 1px solid rgba(255,255,255,.05);
        top:-200px; right:-150px; pointer-events:none;
        animation: slowSpin 70s linear infinite;
      }
      footer::after {
        content:'';
        position:absolute; width:280px; height:280px; border-radius:50%;
        border: 1px dashed rgba(255,255,255,.04);
        bottom:-80px; left:-60px; pointer-events:none;
        animation: slowSpinRev 50s linear infinite;
      }
      .footer-inner {
        max-width:1200px; margin:0 auto;
        display:grid; grid-template-columns: 1.5fr 1fr 1fr;
        gap:3rem; position:relative; z-index:1;
      }
      @media(max-width:768px){ .footer-inner{ grid-template-columns:1fr; gap:2rem; } }
      .footer-logo {
        font-size:1.05rem; font-weight:800; letter-spacing:.14em;
        color: var(--md-inverse-primary); margin-bottom:.5rem;
      }
      .footer-tagline { font-size:.88rem; color:rgba(255,255,255,.45); line-height:1.6; margin-bottom:1.5rem; }
      .footer-col-title {
        font-size:.68rem; font-weight:700; letter-spacing:.14em;
        text-transform:uppercase; color:var(--md-inverse-primary); margin-bottom:1rem;
      }
      .f-item {
        display:flex; align-items:flex-start; gap:.6rem;
        font-size:.85rem; color:rgba(255,255,255,.6); margin-bottom:.75rem; line-height:1.55;
      }
      .f-item svg { flex-shrink:0; margin-top:2px; }
      .f-item a { color:rgba(255,255,255,.6); transition:color var(--dur-short); }
      .f-item a:hover { color:#fff; }
      .f-dir { font-size:.8rem; color:rgba(255,255,255,.5); margin-bottom:.7rem; line-height:1.55; }
      .f-dir strong { color:rgba(255,255,255,.85); display:block; }
      .f-dir a { color:rgba(255,255,255,.45); }
      hr.fhr { border:none; border-top:1px solid rgba(255,255,255,.07); max-width:1200px; margin:2.5rem auto 1.5rem; }
      .footer-bottom {
        max-width:1200px; margin:0 auto;
        display:flex; justify-content:space-between; flex-wrap:wrap; gap:.75rem;
        font-size:.75rem; color:rgba(255,255,255,.28);
      }
</style>

<!-- ═══ FOOTER ═══ -->
    <footer>
      <div class="footer-inner">
        <div class="reveal">
          <div class="footer-logo">TECHNOPHARMED</div>
          <p class="footer-tagline">Compromiso, Respaldo e Innovación.<br/>Soluciones farmacéuticas de clase mundial.</p>
        </div>

        <div class="reveal stagger-1">
          <p class="footer-col-title">Contacto</p>
          <div class="f-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z" stroke="rgba(255,255,255,.55)" stroke-width="2"/><circle cx="12" cy="9" r="2.5" stroke="rgba(255,255,255,.55)" stroke-width="2"/></svg>
            <span>Carrera 3F Nº 32A-13, Manizales, Colombia.</span>
          </div>
          <div class="f-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" stroke="rgba(255,255,255,.55)" stroke-width="2"/></svg>
            <a href="tel:+573138311426">(+57) 313 831 1426</a>
          </div>
          <div class="f-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="rgba(255,255,255,.55)" stroke-width="2"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke="rgba(255,255,255,.55)" stroke-width="2"/></svg>
            <a href="https://www.technopharmed.com" target="_blank">www.technopharmed.com</a>
          </div>
        </div>

        <div class="reveal stagger-2">
          <p class="footer-col-title">Directorio</p>
          <div class="f-dir"><strong>Gerencia — Ing. Juan Quintero</strong><a href="mailto:gerencia@technopharmed.com">gerencia@technopharmed.com</a> · 313 831 1426</div>
          <div class="f-dir"><strong>Administrativo — Claudia Santa</strong><a href="mailto:administrativo@technopharmed.com">administrativo@technopharmed.com</a> · 313 627 36 94</div>
        </div>
      </div>
      <hr class="fhr" />
      <div class="footer-bottom">
        <span>© 2025 Technopharmed. Todos los derechos reservados.</span>
        <span>Manizales, Colombia</span>
      </div>
    </footer>
