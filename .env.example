# ──────────────────────────────────────────────────────
# Google Sheets API (Formulario de Contacto)
# ──────────────────────────────────────────────────────
GOOGLE_SHEET_ID=tu_id_de_google_sheet_aqui
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...tu_clave_privada_aqui...\n-----END PRIVATE KEY-----

# ──────────────────────────────────────────────────────
# Cloudflare Turnstile CAPTCHA
# ──────────────────────────────────────────────────────
PUBLIC_TURNSTILE_SITE_KEY=tu_site_key_aqui
TURNSTILE_SECRET_KEY=tu_secret_key_aqui

# ──────────────────────────────────────────────────────
# Notas de despliegue en DigitalOcean App Platform
# ──────────────────────────────────────────────────────
# Build Command : npm run build
# Run Command   : node ./dist/server/entry.mjs
# HTTP Port     : (asignado automáticamente por DO via $PORT)
# Añade todas las variables de arriba en el panel de
# Environment Variables de DigitalOcean.